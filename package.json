{
  "name": "roomshare",
  "version": "0.1.0",
  "private": true,
  "sideEffects": false,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "node scripts/run-dev.js",
    "dev:fresh": "node scripts/dev-fresh.js",
    "build": "next build --webpack",
    "start": "next start --hostname 0.0.0.0",
    "lint": "eslint src --ext .ts,.tsx --cache --cache-location .next/cache/eslint",
    "typecheck": "rm -rf .next/types .next/dev/types && next typegen && tsc --noEmit",
    "verify": "node verify.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:ci": "NODE_OPTIONS=--experimental-vm-modules jest --ci --coverage --maxWorkers=2",
    "test:unit": "jest --testPathPatterns=\"src/__tests__/(lib|hooks)/\" --testPathIgnorePatterns=\"filter-regression\"",
    "test:components": "jest --testPathPatterns=\"src/__tests__/(components|pages)/\"",
    "test:api": "jest --testPathPatterns=\"src/__tests__/(api|actions)/\"",
    "test:filters": "jest src/__tests__/lib/filter-schema.test.ts src/__tests__/integration/ src/__tests__/property/ src/__tests__/e2e/",
    "test:filters:schema": "jest src/__tests__/lib/filter-schema.test.ts",
    "test:filters:integration": "jest src/__tests__/integration/",
    "test:filters:property": "jest src/__tests__/property/",
    "test:filters:e2e": "jest src/__tests__/e2e/",
    "test:filters:regression": "jest src/__tests__/lib/filter-regression.test.ts",
    "test:filters:perf": "jest src/__tests__/performance/ --testTimeout=60000",
    "test:load": "~/bin/k6 run tests/load/test-401-response-times.js",
    "test:filters:all": "jest src/__tests__/lib/filter-schema.test.ts src/__tests__/lib/filter-regression.test.ts src/__tests__/integration/ src/__tests__/property/ src/__tests__/e2e/ src/__tests__/performance/ --testTimeout=60000",
    "clean:next-locks": "rm -rf .next/dev/lock 2>/dev/null || true",
    "seed:e2e": "node scripts/seed-e2e.js",
    "test:e2e": "pnpm run seed:e2e && playwright test",
    "test:e2e:ci": "playwright test --project=chromium --reporter=list,html",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:mobile": "playwright test --project='Mobile Chrome' --project='Mobile Safari'",
    "test:e2e:anon": "playwright test --project=chromium-anon",
    "test:e2e:search-release-gate:ssr": "node scripts/run-search-release-gate.js ssr",
    "test:e2e:search-release-gate:client": "node scripts/run-search-release-gate.js client",
    "test:e2e:search-release-gate": "pnpm run test:e2e:search-release-gate:ssr && pnpm run test:e2e:search-release-gate:client",
    "scan:public-payload-pii": "node scripts/scan-public-payload-pii.js",
    "geocode:compare": "npx ts-node scripts/geocode-accuracy-check.ts",
    "geocode:compare:extended": "npx ts-node scripts/geocode-accuracy-extended.ts",
    "geocode:compare:json": "npx ts-node scripts/geocode-accuracy-extended.ts --json",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,css,json}\""
  },
  "dependencies": {
    "@ai-sdk/groq": "^2.0.38",
    "@ai-sdk/react": "^2.0.181",
    "@auth/prisma-adapter": "^2.11.2",
    "@google/genai": "^1.50.1",
    "@marsidev/react-turnstile": "^1.5.1",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/nextjs": "^10.50.0",
    "@supabase/supabase-js": "^2.104.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "ai": "^5.0.179",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "maplibre-gl": "^5.24.0",
    "next": "^16.2.4",
    "next-auth": "5.0.0-beta.30",
    "pgvector": "^0.2.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-map-gl": "^8.1.1",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "stripe": "^22.1.0",
    "tailwind-merge": "^3.5.0",
    "use-debounce": "^10.1.1",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@electric-sql/pglite": "^0.4.4",
    "@lhci/cli": "^0.15.1",
    "@napi-rs/canvas": "^0.1.100",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/geojson": "^7946.0.16",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "fast-check": "^4.7.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.8.3",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.2.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "whatwg-fetch": "^3.6.20"
  },
  "pnpm": {
    "overrides": {
      "effect": ">=3.20.0",
      "path-to-regexp@<0.1.13": ">=0.1.13"
    }
  }
}
