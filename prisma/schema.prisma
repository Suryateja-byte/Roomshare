generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "debian-openssl-3.0.x", "windows"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id                      String                 @id @default(cuid())
  name                    String?
  email                   String?                @unique
  emailVerified           DateTime?
  image                   String?
  password                String?
  passwordChangedAt       DateTime?              // H-1: session invalidation on password change
  bio                     String?
  countryOfOrigin         String?
  languages               String[]
  isVerified              Boolean                @default(false)
  isAdmin                 Boolean                @default(false)
  isSuspended             Boolean                @default(false)
  notificationPreferences Json?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  accounts                Account[]
  listings                Listing[]
  messages                Message[]
  sessions                Session[]
  conversations           Conversation[]         @relation("ConversationParticipants")
  savedListings           SavedListing[]
  reviewsWritten          Review[]               @relation("ReviewAuthor")
  reviewsReceived         Review[]               @relation("ReviewTarget")
  reportsMade             Report[]               @relation("ReportsMade")
  reportsAboutMe          Report[]               @relation("ReportsAboutUser")
  reportsReviewed         Report[]               @relation("ReportsReviewed")
  recentlyViewed          RecentlyViewed[]
  notifications           Notification[]
  verificationRequests    VerificationRequest[]
  verificationUploads     VerificationUpload[]
  savedSearches           SavedSearch[]
  alertSubscriptions       AlertSubscription[]
  alertDeliveries          AlertDelivery[]
  blockedUsers            BlockedUser[]          @relation("BlocksMade")
  blockedByUsers          BlockedUser[]          @relation("BlocksReceived")
  auditLogs               AuditLog[]             @relation("AuditLogs")
  typingStatuses          TypingStatus[]
  conversationDeletions   ConversationDeletion[]
}

model VerificationToken {
  identifier        String    @unique
  tokenHash         String?   @unique @map("token_hash")
  expires           DateTime?
  pendingTokenHash  String?   @unique @map("pending_token_hash")
  pendingExpires    DateTime? @map("pending_expires")
  pendingPreparedAt DateTime? @map("pending_prepared_at")

  @@index([expires])
  @@index([pendingExpires])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  tokenHash String   @unique @map("token_hash")
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, tokenHash])
  @@index([expires])
}

model Listing {
  id                      String                    @id @default(cuid())
  ownerId                 String
  title                   String
  description             String
  price                   Decimal                   @db.Decimal(10, 2)
  images                  String[]                  @default([])
  amenities               String[]
  houseRules              String[]
  leaseDuration           String?
  roomType                String?
  normalizedAddress       String?
  physicalUnitId          String?                   @map("physical_unit_id")
  householdLanguages      String[]                  @default([]) @map("household_languages")
  primaryHomeLanguage     String?                   @map("primary_home_language")
  genderPreference        String?
  householdGender         String?
  totalSlots              Int
  availableSlots          Int
  openSlots               Int?
  moveInDate              DateTime?
  availableUntil          DateTime?                 @db.Date
  minStayMonths           Int                       @default(1)
  lastConfirmedAt         DateTime?
  statusReason            String?                   @db.VarChar(64)
  freshnessReminderSentAt DateTime?
  freshnessWarningSentAt  DateTime?
  autoPausedAt            DateTime?
  status                  ListingStatus             @default(ACTIVE)
  viewCount               Int                       @default(0)
  version                 Int                       @default(1) // Optimistic locking for race-safe updates
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  owner                   User                      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  location                Location?
  conversations           Conversation[]
  savedBy                 SavedListing[]
  reviews                 Review[]
  reports                 Report[]
  recentlyViewed          RecentlyViewed[]

  @@index([ownerId])
  // Defined as a PARTIAL index (WHERE status IN ACTIVE, PAUSED) in the migration SQL.
  // Prisma's introspection cannot round-trip WHERE predicates; do NOT regenerate via `db pull`.
  @@index([ownerId, normalizedAddress])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([status, price])
  @@index([lastConfirmedAt])
}

model SavedListing {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([listingId])
}

model Review {
  id           String   @id @default(cuid())
  authorId     String
  listingId    String?
  targetUserId String?
  rating       Int
  comment      String
  createdAt    DateTime @default(now())

  author     User            @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  listing    Listing?        @relation(fields: [listingId], references: [id], onDelete: Cascade)
  targetUser User?           @relation("ReviewTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  response   ReviewResponse?

  // One review per user per listing (duplicate prevention)
  @@unique([authorId, listingId])
  @@index([listingId])
  @@index([targetUserId])
}

enum ListingStatus {
  ACTIVE
  PAUSED
  RENTED
}

enum ReportStatus {
  OPEN
  RESOLVED
  DISMISSED
}

enum ReportKind {
  ABUSE_REPORT
  PRIVATE_FEEDBACK
}

model Report {
  id         String       @id @default(cuid())
  listingId  String
  reporterId String
  reason     String
  details    String?
  // Private feedback. Never exposed in public review or listing surfaces.
  // See CFM-703. `kind = PRIVATE_FEEDBACK` rows MUST NOT bleed into
  // /api/reviews, /api/listings*, or any public viewer-state payload.
  kind         ReportKind   @default(ABUSE_REPORT)
  targetUserId String?      @db.Text
  status     ReportStatus @default(OPEN)
  adminNotes String?
  reviewedBy String?
  resolvedAt DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  listing    Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reporter   User    @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  reviewer   User?   @relation("ReportsReviewed", fields: [reviewedBy], references: [id], onDelete: SetNull)
  targetUser User?   @relation("ReportsAboutUser", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([listingId])
  @@index([kind, status])
  @@index([targetUserId])
}

model Location {
  id        String                   @id @default(cuid())
  listingId String                   @unique
  address   String
  city      String
  state     String
  zip       String
  coords    Unsupported("geometry")?
  listing   Listing                  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([coords], map: "location_idx", type: Gist)
}

model Conversation {
  id             String                 @id @default(cuid())
  listingId      String
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  deletedAt      DateTime? // Admin-level delete: hides from ALL participants
  listing        Listing                @relation(fields: [listingId], references: [id], onDelete: Cascade)
  messages       Message[]
  participants   User[]                 @relation("ConversationParticipants")
  typingStatuses TypingStatus[]
  deletions      ConversationDeletion[] // Per-user deletion records

  @@index([listingId])
}

model ConversationDeletion {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  deletedAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  senderId       String
  conversationId String
  content        String
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())
  deletedAt      DateTime? // Soft delete timestamp
  deletedBy      String? // User who deleted (for audit)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  // P2-16: Composite index for efficient message retrieval by conversation
  // Queries like: SELECT * FROM Message WHERE conversationId = ? ORDER BY createdAt
  @@index([conversationId, createdAt])
}

model RecentlyViewed {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  viewedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId, viewedAt])
}

enum NotificationType {
  BOOKING_REQUEST
  BOOKING_ACCEPTED
  BOOKING_REJECTED
  BOOKING_CANCELLED
  BOOKING_HOLD_REQUEST
  BOOKING_EXPIRED
  BOOKING_HOLD_EXPIRED
  NEW_MESSAGE
  NEW_REVIEW
  LISTING_SAVED
  SEARCH_ALERT
  LISTING_FRESHNESS_REMINDER
  LISTING_STALE_WARNING
  LISTING_AUTO_PAUSED
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model VerificationRequest {
  id                 String               @id @default(cuid())
  userId             String
  documentType       String // "passport", "driver_license", "national_id"
  documentUrl        String? // Legacy public URL; migrated to private documentPath.
  selfieUrl          String? // Legacy public URL; migrated to private selfiePath.
  documentPath       String? // Private Supabase Storage path in verification-documents.
  selfiePath         String? // Private Supabase Storage path in verification-documents.
  documentMimeType   String?
  selfieMimeType     String?
  documentsExpireAt  DateTime?
  documentsDeletedAt DateTime?
  status             VerificationStatus   @default(PENDING)
  adminNotes         String? // Notes from admin on rejection
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  reviewedAt         DateTime?
  reviewedBy         String? // Admin user ID who reviewed
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  uploads            VerificationUpload[]

  @@index([userId])
  @@index([status])
  @@index([documentsExpireAt])
}

model VerificationUpload {
  id          String               @id @default(cuid())
  userId      String
  requestId   String?
  kind        String // "document" | "selfie"
  storagePath String               @unique
  mimeType    String
  sizeBytes   Int
  createdAt   DateTime             @default(now())
  expiresAt   DateTime
  consumedAt  DateTime?
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  request     VerificationRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)

  @@index([userId, kind, consumedAt, expiresAt])
  @@index([requestId])
  @@index([expiresAt])
}

enum AlertFrequency {
  INSTANT
  DAILY
  WEEKLY
}

model SavedSearch {
  id                         String              @id @default(cuid())
  userId                     String
  name                       String
  query                      String?
  filters                    Json // Store all filter params as JSON
  searchSpecJson             Json?               @map("search_spec_json")
  searchSpecHash             String?             @map("search_spec_hash")
  embeddingVersionAtSave     String?             @map("embedding_version_at_save")
  rankerProfileVersionAtSave String?             @map("ranker_profile_version_at_save")
  unitIdentityEpochFloor     Int?                @map("unit_identity_epoch_floor")
  active                     Boolean             @default(true)
  alertEnabled               Boolean             @default(true)
  alertFrequency             AlertFrequency      @default(DAILY)
  lastAlertAt                DateTime?
  createdAt                  DateTime            @default(now())
  user                       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  alertSubscriptions         AlertSubscription[]
  alertDeliveries            AlertDelivery[]

  @@index([userId])
  @@index([alertEnabled, lastAlertAt])
  @@index([active, userId], map: "SavedSearch_active_userId_idx")
  @@index([searchSpecHash], map: "SavedSearch_search_spec_hash_idx")
}

model AlertSubscription {
  id              String          @id @default(cuid())
  savedSearchId   String          @map("saved_search_id")
  userId          String          @map("user_id")
  channel         String          @default("EMAIL")
  frequency       AlertFrequency  @default(DAILY)
  active          Boolean         @default(true)
  lastDeliveredAt DateTime?       @map("last_delivered_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  savedSearch     SavedSearch     @relation(fields: [savedSearchId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries      AlertDelivery[]

  @@unique([savedSearchId, channel], map: "alert_subscriptions_saved_search_channel_key")
  @@index([active, channel, frequency, lastDeliveredAt], map: "alert_subscriptions_active_channel_frequency_last_idx")
  @@index([userId, active], map: "alert_subscriptions_user_active_idx")
  @@map("alert_subscriptions")
}

model AlertDelivery {
  id                      String            @id @default(cuid())
  subscriptionId          String            @map("subscription_id")
  savedSearchId           String            @map("saved_search_id")
  userId                  String            @map("user_id")
  channel                 String            @default("EMAIL")
  deliveryKind            String            @default("SCHEDULED") @map("delivery_kind")
  status                  String            @default("PENDING")
  dropReason              String?           @map("drop_reason")
  idempotencyKey          String            @unique(map: "alert_deliveries_idempotency_key_key") @map("idempotency_key")
  targetListingId         String?           @map("target_listing_id")
  targetUnitId            String?           @map("target_unit_id")
  targetInventoryId       String?           @map("target_inventory_id")
  targetUnitIdentityEpoch Int?              @map("target_unit_identity_epoch")
  queryHash               String?           @map("query_hash")
  embeddingVersion        String?           @map("embedding_version")
  rankerProfileVersion    String?           @map("ranker_profile_version")
  projectionEpoch         BigInt?           @map("projection_epoch")
  newListingsCount        Int               @default(0) @map("new_listings_count")
  payload                 Json              @default("{}")
  scheduledFor            DateTime          @default(now()) @map("scheduled_for")
  expiresAt               DateTime          @default(dbgenerated("(CURRENT_TIMESTAMP + INTERVAL '7 days')")) @map("expires_at")
  claimedAt               DateTime?         @map("claimed_at")
  deliveredAt             DateTime?         @map("delivered_at")
  droppedAt               DateTime?         @map("dropped_at")
  lastError               String?           @map("last_error")
  attemptCount            Int               @default(0) @map("attempt_count")
  createdAt               DateTime          @default(now()) @map("created_at")
  updatedAt               DateTime          @updatedAt @map("updated_at")
  subscription            AlertSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  savedSearch             SavedSearch       @relation(fields: [savedSearchId], references: [id], onDelete: Cascade)
  user                    User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, scheduledFor], map: "alert_deliveries_status_scheduled_idx")
  @@index([subscriptionId, status, scheduledFor], map: "alert_deliveries_subscription_status_scheduled_idx")
  @@index([savedSearchId, createdAt], map: "alert_deliveries_saved_search_created_idx")
  @@index([targetUnitId, targetInventoryId, status], map: "alert_deliveries_target_status_idx")
  @@index([userId, status], map: "alert_deliveries_user_status_idx")
  @@map("alert_deliveries")
}

model ReviewResponse {
  id        String   @id @default(cuid())
  reviewId  String   @unique
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}

// Rate Limiting (Database-backed for Vercel serverless)
model RateLimitEntry {
  id          String   @id @default(cuid())
  identifier  String // IP or userId:endpoint
  endpoint    String
  count       Int      @default(1)
  windowStart DateTime @default(now())
  expiresAt   DateTime

  @@unique([identifier, endpoint])
  @@index([expiresAt])
}

// User Blocking
model BlockedUser {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("BlocksMade", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

// Admin Audit Trail - Immutable log of all admin actions for security/compliance
model AuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String // e.g., "USER_SUSPENDED", "LISTING_DELETED", "REPORT_RESOLVED"
  targetType String // e.g., "User", "Listing", "Report"
  targetId   String
  details    Json? // Additional context (old/new values, reason, etc.)
  ipAddress  String? // For security tracking
  createdAt  DateTime @default(now())

  admin User @relation("AuditLogs", fields: [adminId], references: [id])

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@index([action])
}

model TypingStatus {
  id             String   @id @default(cuid())
  userId         String
  conversationId String
  isTyping       Boolean  @default(false)
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
  @@index([conversationId])
  @@index([updatedAt])
}

// Idempotency Keys for preventing duplicate submissions (e.g., booking, payment)
// Keys are stored with cached results and expire after 24 hours
// P0-04: Uses INSERT ON CONFLICT + FOR UPDATE for atomic claim with no race window
model IdempotencyKey {
  id          String   @id @default(cuid())
  key         String // Client-provided key (unique per user+endpoint)
  userId      String // User who made the request
  endpoint    String // Which endpoint (e.g., "startConversation")
  status      String   @default("processing") // 'processing' | 'completed'
  requestHash String // SHA-256 hash of request body for replay detection
  resultData  Json? // Cached result of the operation
  createdAt   DateTime @default(now())
  expiresAt   DateTime // Auto-expire after 24 hours

  @@unique([userId, endpoint, key], map: "IdempotencyKey_user_endpoint_key_idx")
  @@index([expiresAt])
  @@index([userId, endpoint])
}

enum ProductCode {
  CONTACT_PACK_3
  MOVERS_PASS_30D
}

enum ContactKind {
  MESSAGE_START
  REVEAL_PHONE
}

enum PaymentStatus {
  CHECKOUT_CREATED
  CHECKOUT_COMPLETED
  SUCCEEDED
  FAILED
  CANCELED
}

enum RefundStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELED
}

enum EntitlementGrantType {
  PACK
  PASS
}

enum EntitlementGrantStatus {
  ACTIVE
  FROZEN
  REVOKED
  EXPIRED
}

enum PaymentDisputeStatus {
  OPEN
  WON
  LOST
}

enum ContactConsumptionSource {
  FREE
  PACK
  PASS
}

enum EntitlementFreezeReason {
  NONE
  CHARGEBACK_PENDING
  FRAUD_REVIEW
  MANUAL
}

enum ContactRestorationState {
  NONE
  RESTORED_HOST_BOUNCE
  RESTORED_HOST_BAN
  RESTORED_HOST_MASS_DEACTIVATED
  RESTORED_HOST_GHOST_SLA
  RESTORED_SUPPORT
}

enum ContactRestorationReason {
  HOST_BOUNCE
  HOST_BAN
  HOST_MASS_DEACTIVATED
  HOST_GHOST_SLA
  SUPPORT
}

model StripeEvent {
  id               String   @id @default(cuid())
  stripeEventId    String   @unique @map("stripe_event_id")
  eventType        String   @map("event_type")
  stripeObjectId   String?  @map("stripe_object_id")
  payload          Json
  livemode         Boolean  @default(false)
  signatureVerified Boolean @default(true) @map("signature_verified")
  processingStatus String   @default("PENDING") @map("processing_status")
  attemptCount     Int      @default(0) @map("attempt_count")
  nextAttemptAt    DateTime @default(now()) @map("next_attempt_at")
  lastError        String?  @map("last_error")
  processedBy      String?  @map("processed_by")
  receivedAt       DateTime @default(now()) @map("received_at")
  processedAt      DateTime? @map("processed_at")

  @@index([eventType, receivedAt], map: "stripe_events_type_received_at_idx")
  @@index([processingStatus, nextAttemptAt, receivedAt], map: "stripe_events_processing_idx")
  @@index([livemode, eventType, receivedAt], map: "stripe_events_livemode_type_idx")
  @@map("stripe_events")
}

model Payment {
  id                     String        @id @default(cuid())
  userId                 String        @map("user_id")
  productCode            ProductCode   @map("product_code")
  status                 PaymentStatus @default(CHECKOUT_CREATED)
  stripeCheckoutSessionId String?      @unique @map("stripe_checkout_session_id")
  stripePaymentIntentId  String?       @unique @map("stripe_payment_intent_id")
  stripeCustomerId       String?       @map("stripe_customer_id")
  amount                 Decimal       @db.Decimal(10, 2)
  currency               String        @default("usd")
  livemode               Boolean       @default(false)
  fraudFlag              Boolean       @default(false) @map("fraud_flag")
  autoRefundStatus       String?       @map("auto_refund_status")
  originStripeEventId    String?       @map("origin_stripe_event_id")
  metadata               Json?
  paidAt                 DateTime?     @map("paid_at")
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")

  @@index([userId, status], map: "payments_user_status_idx")
  @@index([productCode, status], map: "payments_product_status_idx")
  @@index([livemode, status, createdAt], map: "payments_livemode_status_idx")
  @@map("payments")
}

model Refund {
  id            String       @id @default(cuid())
  paymentId     String       @map("payment_id")
  stripeRefundId String      @unique @map("stripe_refund_id")
  amount        Decimal      @db.Decimal(10, 2)
  currency      String       @default("usd")
  status        RefundStatus @default(PENDING)
  reason        String?
  originStripeEventId String? @map("origin_stripe_event_id")
  source        String?
  manualReviewRequired Boolean @default(false) @map("manual_review_required")
  metadata      Json?
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@index([paymentId], map: "refunds_payment_id_idx")
  @@map("refunds")
}

model EntitlementGrant {
  id          String                 @id @default(cuid())
  userId      String                 @map("user_id")
  productCode ProductCode            @map("product_code")
  contactKind ContactKind            @map("contact_kind")
  grantType   EntitlementGrantType   @map("grant_type")
  status      EntitlementGrantStatus @default(ACTIVE)
  creditCount Int?                   @map("credit_count")
  originalCreditCount Int?           @map("original_credit_count")
  paymentId   String?                @unique @map("payment_id")
  sourceRefundId String?             @map("source_refund_id")
  idempotencyKey String?             @map("idempotency_key")
