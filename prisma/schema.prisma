generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "debian-openssl-3.0.x", "windows"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id                      String                 @id @default(cuid())
  name                    String?
  email                   String?                @unique
  emailVerified           DateTime?
  image                   String?
  password                String?
  passwordChangedAt       DateTime?              // H-1: session invalidation on password change
  bio                     String?
  countryOfOrigin         String?
  languages               String[]
  isVerified              Boolean                @default(false)
  isAdmin                 Boolean                @default(false)
  isSuspended             Boolean                @default(false)
  notificationPreferences Json?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  accounts                Account[]
  listings                Listing[]
  messages                Message[]
  sessions                Session[]
  conversations           Conversation[]         @relation("ConversationParticipants")
  savedListings           SavedListing[]
  reviewsWritten          Review[]               @relation("ReviewAuthor")
  reviewsReceived         Review[]               @relation("ReviewTarget")
  bookings                Booking[]
  reportsMade             Report[]               @relation("ReportsMade")
  reportsAboutMe          Report[]               @relation("ReportsAboutUser")
  reportsReviewed         Report[]               @relation("ReportsReviewed")
  recentlyViewed          RecentlyViewed[]
  notifications           Notification[]
  verificationRequests    VerificationRequest[]
  savedSearches           SavedSearch[]
  blockedUsers            BlockedUser[]          @relation("BlocksMade")
  blockedByUsers          BlockedUser[]          @relation("BlocksReceived")
  auditLogs               AuditLog[]             @relation("AuditLogs")
  bookingAuditLogs        BookingAuditLog[]      @relation("BookingAuditActor")
  typingStatuses          TypingStatus[]
  conversationDeletions   ConversationDeletion[]
}

model VerificationToken {
  identifier String
  tokenHash  String   @unique @map("token_hash")
  expires    DateTime

  @@unique([identifier, tokenHash])
  @@index([expires])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  tokenHash String   @unique @map("token_hash")
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, tokenHash])
  @@index([expires])
}

model Listing {
  id                      String                    @id @default(cuid())
  ownerId                 String
  title                   String
  description             String
  price                   Decimal                   @db.Decimal(10, 2)
  images                  String[]                  @default([])
  amenities               String[]
  houseRules              String[]
  leaseDuration           String?
  roomType                String?
  householdLanguages      String[]                  @default([]) @map("household_languages")
  primaryHomeLanguage     String?                   @map("primary_home_language")
  genderPreference        String?
  householdGender         String?
  totalSlots              Int
  availableSlots          Int
  openSlots               Int?
  moveInDate              DateTime?
  availableUntil          DateTime?                 @db.Date
  minStayMonths           Int                       @default(1)
  lastConfirmedAt         DateTime?
  availabilitySource      ListingAvailabilitySource @default(LEGACY_BOOKING)
  needsMigrationReview    Boolean                   @default(false)
  statusReason            String?                   @db.VarChar(64)
  freshnessReminderSentAt DateTime?
  freshnessWarningSentAt  DateTime?
  autoPausedAt            DateTime?
  status                  ListingStatus             @default(ACTIVE)
  viewCount               Int                       @default(0)
  version                 Int                       @default(1) // Optimistic locking for race-safe updates
  bookingMode             String                    @default("SHARED") @map("booking_mode")
  holdTtlMinutes          Int                       @default(15) @map("hold_ttl_minutes")
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  owner                   User                      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  location                Location?
  conversations           Conversation[]
  savedBy                 SavedListing[]
  reviews                 Review[]
  bookings                Booking[]
  dayInventory            ListingDayInventory[]
  reports                 Report[]
  recentlyViewed          RecentlyViewed[]

  @@index([ownerId])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([status, price])
  @@index([availabilitySource, status])
  @@index([lastConfirmedAt])
}

model SavedListing {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([listingId])
}

model Review {
  id           String   @id @default(cuid())
  authorId     String
  listingId    String?
  targetUserId String?
  rating       Int
  comment      String
  createdAt    DateTime @default(now())

  author     User            @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  listing    Listing?        @relation(fields: [listingId], references: [id], onDelete: Cascade)
  targetUser User?           @relation("ReviewTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  response   ReviewResponse?

  // One review per user per listing (duplicate prevention)
  @@unique([authorId, listingId])
  @@index([listingId])
  @@index([targetUserId])
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  HELD
  EXPIRED
}

enum ListingStatus {
  ACTIVE
  PAUSED
  RENTED
}

enum ListingAvailabilitySource {
  LEGACY_BOOKING
  HOST_MANAGED
}

model Booking {
  id              String        @id @default(cuid())
  listingId       String
  tenantId        String?
  startDate       DateTime
  endDate         DateTime
  status          BookingStatus @default(PENDING)
  totalPrice      Decimal       @db.Decimal(10, 2)
  rejectionReason String? // Optional reason when host rejects booking
  slotsRequested  Int           @default(1) // Phase 2: Number of slots this booking reserves
  version         Int           @default(1) // P0-04: Optimistic locking for race-safe updates
  heldUntil       DateTime?                 // Phase 4: Expiry time for HELD bookings; DB CHECK requires non-null when status=HELD
  heldAt          DateTime?                 // Phase 1: Timestamp when hold was created
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  listing          Listing          @relation(fields: [listingId], references: [id], onDelete: Restrict)
  tenant           User?            @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  bookingAuditLogs BookingAuditLog[]

  // Duplicate prevention: partial unique index in raw SQL migration (allows re-application after EXPIRED/REJECTED/CANCELLED)
  // See: migrations/*_soft_holds_partial_unique_index/migration.sql
  @@index([listingId, status])
  @@index([tenantId])
  @@index([listingId, status, startDate, endDate])
  @@index([status, heldUntil]) // Cron sweep-expired-holds: WHERE status='HELD' AND heldUntil <= NOW()
}

model ListingDayInventory {
  listingId      String   @map("listing_id")
  day            DateTime @db.Date
  totalSlots     Int      @map("total_slots")
  heldSlots      Int      @default(0) @map("held_slots")
  acceptedSlots  Int      @default(0) @map("accepted_slots")
  version        BigInt   @default(0)
  updatedAt      DateTime @default(now()) @map("updated_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@id([listingId, day])
  @@map("listing_day_inventory")
}

enum ReportStatus {
  OPEN
  RESOLVED
  DISMISSED
}

enum ReportKind {
  ABUSE_REPORT
  PRIVATE_FEEDBACK
}

model Report {
  id         String       @id @default(cuid())
  listingId  String
  reporterId String
  reason     String
  details    String?
  // Private feedback. Never exposed in public review or listing surfaces.
  // See CFM-703. `kind = PRIVATE_FEEDBACK` rows MUST NOT bleed into
  // /api/reviews, /api/listings*, or any public viewer-state payload.
  kind         ReportKind   @default(ABUSE_REPORT)
  targetUserId String?      @db.Text
  status     ReportStatus @default(OPEN)
  adminNotes String?
  reviewedBy String?
  resolvedAt DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  listing    Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reporter   User    @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  reviewer   User?   @relation("ReportsReviewed", fields: [reviewedBy], references: [id], onDelete: SetNull)
  targetUser User?   @relation("ReportsAboutUser", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([listingId])
  @@index([kind, status])
  @@index([targetUserId])
}

model Location {
  id        String                   @id @default(cuid())
  listingId String                   @unique
  address   String
  city      String
  state     String
  zip       String
  coords    Unsupported("geometry")?
  listing   Listing                  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([coords], map: "location_idx", type: Gist)
}

model Conversation {
  id             String                 @id @default(cuid())
  listingId      String
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  deletedAt      DateTime? // Admin-level delete: hides from ALL participants
  listing        Listing                @relation(fields: [listingId], references: [id], onDelete: Cascade)
  messages       Message[]
  participants   User[]                 @relation("ConversationParticipants")
  typingStatuses TypingStatus[]
  deletions      ConversationDeletion[] // Per-user deletion records

  @@index([listingId])
}

model ConversationDeletion {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  deletedAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  senderId       String
  conversationId String
  content        String
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())
  deletedAt      DateTime? // Soft delete timestamp
  deletedBy      String? // User who deleted (for audit)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  // P2-16: Composite index for efficient message retrieval by conversation
  // Queries like: SELECT * FROM Message WHERE conversationId = ? ORDER BY createdAt
  @@index([conversationId, createdAt])
}

model RecentlyViewed {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  viewedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId, viewedAt])
}

enum NotificationType {
  BOOKING_REQUEST
  BOOKING_ACCEPTED
  BOOKING_REJECTED
  BOOKING_CANCELLED
  BOOKING_HOLD_REQUEST
  BOOKING_EXPIRED
  BOOKING_HOLD_EXPIRED
  NEW_MESSAGE
  NEW_REVIEW
  LISTING_SAVED
  SEARCH_ALERT
  LISTING_FRESHNESS_REMINDER
  LISTING_STALE_WARNING
  LISTING_AUTO_PAUSED
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model VerificationRequest {
  id           String             @id @default(cuid())
  userId       String
  documentType String // "passport", "driver_license", "national_id"
  documentUrl  String // URL to uploaded document image
  selfieUrl    String? // URL to selfie for matching
  status       VerificationStatus @default(PENDING)
  adminNotes   String? // Notes from admin on rejection
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  reviewedAt   DateTime?
  reviewedBy   String? // Admin user ID who reviewed
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

enum AlertFrequency {
  INSTANT
  DAILY
  WEEKLY
}

model SavedSearch {
  id             String         @id @default(cuid())
  userId         String
  name           String
  query          String?
  filters        Json // Store all filter params as JSON
  alertEnabled   Boolean        @default(true)
  alertFrequency AlertFrequency @default(DAILY)
  lastAlertAt    DateTime?
  createdAt      DateTime       @default(now())
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([alertEnabled, lastAlertAt])
}

model ReviewResponse {
  id        String   @id @default(cuid())
  reviewId  String   @unique
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

// Booking Audit Trail - Immutable append-only log of booking state transitions
model BookingAuditLog {
  id             String   @id @default(cuid())
  bookingId      String?  // H-2: nullable for orphaned audit records after user/booking deletion
  action         String   // CREATED, HELD, ACCEPTED, REJECTED, CANCELLED, EXPIRED
  previousStatus String?  // null for CREATED
  newStatus      String
  actorId        String?  // null for system actions (cron sweeper)
  actorType      String   @default("USER") // USER, HOST, SYSTEM, ADMIN
  details        Json?    // slotsRequested, rejectionReason, heldUntil, version, etc.
  ipAddress      String?  // GDPR: if populated in future, must be scrubbed in deleteAccount()
  createdAt      DateTime @default(now())

  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  actor   User?   @relation("BookingAuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([bookingId])
  @@index([bookingId, createdAt])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}

// Rate Limiting (Database-backed for Vercel serverless)
model RateLimitEntry {
  id          String   @id @default(cuid())
  identifier  String // IP or userId:endpoint
  endpoint    String
  count       Int      @default(1)
  windowStart DateTime @default(now())
  expiresAt   DateTime

  @@unique([identifier, endpoint])
  @@index([expiresAt])
}

// User Blocking
model BlockedUser {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("BlocksMade", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

// Admin Audit Trail - Immutable log of all admin actions for security/compliance
model AuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String // e.g., "USER_SUSPENDED", "LISTING_DELETED", "REPORT_RESOLVED"
  targetType String // e.g., "User", "Listing", "Report"
  targetId   String
  details    Json? // Additional context (old/new values, reason, etc.)
  ipAddress  String? // For security tracking
  createdAt  DateTime @default(now())

  admin User @relation("AuditLogs", fields: [adminId], references: [id])

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@index([action])
}

model TypingStatus {
  id             String   @id @default(cuid())
  userId         String
  conversationId String
  isTyping       Boolean  @default(false)
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
  @@index([conversationId])
  @@index([updatedAt])
}

// Idempotency Keys for preventing duplicate submissions (e.g., booking, payment)
// Keys are stored with cached results and expire after 24 hours
// P0-04: Uses INSERT ON CONFLICT + FOR UPDATE for atomic claim with no race window
model IdempotencyKey {
  id          String   @id @default(cuid())
  key         String // Client-provided key (unique per user+endpoint)
  userId      String // User who made the request
  endpoint    String // Which endpoint (e.g., "createBooking")
  status      String   @default("processing") // 'processing' | 'completed'
  requestHash String // SHA-256 hash of request body for replay detection
  resultData  Json? // Cached result of the operation
  createdAt   DateTime @default(now())
  expiresAt   DateTime // Auto-expire after 24 hours

  @@unique([userId, endpoint, key], map: "IdempotencyKey_user_endpoint_key_idx")
  @@index([expiresAt])
  @@index([userId, endpoint])
}
