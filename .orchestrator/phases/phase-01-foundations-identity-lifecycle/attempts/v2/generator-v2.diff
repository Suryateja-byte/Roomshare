+import { recordIdentityMutation } from "@/lib/identity/mutate-unit";
+import { Phase01TestDb } from "@/__tests__/utils/phase01-test-db";
+
+describe("Phase 01 identity mutation integration", () => {
+  let db: Phase01TestDb;
+
+  beforeEach(() => {
+    db = new Phase01TestDb();
+    db.insertUser("moderator-1");
+  });
+
+  afterEach(() => {
+    db.dispose();
+  });
+
+  it("rolls back the ledger row and outbox when a failure happens after the INSERT", async () => {
+    const sourceUnitId = db.insertPhysicalUnit({
+      id: "unit-merge-a",
+      canonical_address_hash: "hash-merge-a",
+      unit_identity_epoch: 2,
+    });
+    const targetUnitId = db.insertPhysicalUnit({
+      id: "unit-merge-target",
+      canonical_address_hash: "hash-merge-target",
+      unit_identity_epoch: 4,
+    });
+    const startingUnits = db.getPhysicalUnits();
+
+    await expect(
+      db.client.$transaction(async (tx) => {
+        const failingTx = {
+          ...tx,
+          outboxEvent: {
+            ...tx.outboxEvent,
+            create: jest
+              .fn()
+              .mockRejectedValue(new Error("synthetic outbox failure")),
+          },
+        };
+
+        await recordIdentityMutation(failingTx as never, {
+          kind: "MERGE",
+          fromUnitIds: [sourceUnitId],
+          toUnitIds: [targetUnitId],
+          reasonCode: "operator_duplicate",
+          operatorId: "moderator-1",
+        });
+      })
+    ).rejects.toThrow("synthetic outbox failure");
+
+    expect(db.getIdentityMutations()).toEqual([]);
+    expect(db.getOutboxEvents()).toEqual([]);
+    expect(
+      db.all<{ count: number }>(`SELECT COUNT(*) as count FROM audit_events`)[0].count
+    ).toBe(0);
+    expect(db.getPhysicalUnits()).toEqual(startingUnits);
+  });
+
+  it("supports SPLIT with multiple to_unit_ids and bumps all affected epochs", async () => {
+    const sourceUnitId = db.insertPhysicalUnit({
+      id: "unit-split-source",
+      canonical_address_hash: "hash-split-source",
+      unit_identity_epoch: 5,
+    });
+    const targetUnitOneId = db.insertPhysicalUnit({
+      id: "unit-split-target-1",
+      canonical_address_hash: "hash-split-target-1",
+      unit_identity_epoch: 1,
+      supersedes_unit_ids: ["legacy-parent"],
+    });
+    const targetUnitTwoId = db.insertPhysicalUnit({
+      id: "unit-split-target-2",
+      canonical_address_hash: "hash-split-target-2",
+      unit_identity_epoch: 3,
+    });
+
+    const result = await db.client.$transaction((tx) =>
+      recordIdentityMutation(tx as never, {
+        kind: "SPLIT",
+        fromUnitIds: [sourceUnitId],
+        toUnitIds: [targetUnitOneId, targetUnitTwoId],
+        reasonCode: "operator_split",
+        operatorId: "moderator-1",
+      })
+    );
+
+    expect(result.affectedUnitIds).toEqual([
+      sourceUnitId,
+      targetUnitOneId,
+      targetUnitTwoId,
+    ]);
+
+    expect(db.getIdentityMutations()).toEqual([
+      expect.objectContaining({
+        kind: "SPLIT",
+        fromUnitIds: [sourceUnitId],
+        toUnitIds: [targetUnitOneId, targetUnitTwoId],
+        resultingEpoch: 6,
+      }),
+    ]);
+
+    expect(db.getOutboxEvents()).toEqual([
+      expect.objectContaining({
+        kind: "IDENTITY_MUTATION",
+        priority: 0,
+        unitIdentityEpoch: 6,
+      }),
+    ]);
+
+    expect(db.getPhysicalUnits()).toEqual(
+      expect.arrayContaining([
+        expect.objectContaining({
+          id: sourceUnitId,
+          unitIdentityEpoch: 6,
+        }),
+        expect.objectContaining({
+          id: targetUnitOneId,
+          unitIdentityEpoch: 6,
+          supersedesUnitIds: ["legacy-parent", sourceUnitId],
+        }),
+        expect.objectContaining({
+          id: targetUnitTwoId,
+          unitIdentityEpoch: 6,
+          supersedesUnitIds: [sourceUnitId],
+        }),
+      ])
+    );
+  });
+
+  it("supports CANONICALIZER_UPGRADE with null operator_id and writes priority 0", async () => {
+    const unitId = db.insertPhysicalUnit({
+      id: "unit-upgrade",
+      canonical_address_hash: "hash-upgrade",
+      unit_identity_epoch: 7,
+    });
+
+    const result = await db.client.$transaction((tx) =>
+      recordIdentityMutation(tx as never, {
+        kind: "CANONICALIZER_UPGRADE",
+        fromUnitIds: [unitId],
+        toUnitIds: [unitId],
+        reasonCode: "canonicalizer_upgrade",
+        operatorId: null,
+      })
+    );
+
+    expect(result.resultingEpoch).toBe(8);
+    expect(db.getIdentityMutations()).toEqual([
+      expect.objectContaining({
+        kind: "CANONICALIZER_UPGRADE",
+        operatorId: null,
+        resultingEpoch: 8,
+      }),
+    ]);
+    expect(db.getOutboxEvents()).toEqual([
+      expect.objectContaining({
+        kind: "IDENTITY_MUTATION",
+        priority: 0,
+      }),
+    ]);
+    expect(
+      db.all<{ actor_role: string; actor_id: string | null }>(
+        `SELECT actor_role, actor_id FROM audit_events`
+      )[0]
+    ).toEqual({
+      actor_role: "system",
+      actor_id: null,
+    });
+  });
+});
diff --git a/src/__tests__/utils/phase01-test-db.ts b/src/__tests__/utils/phase01-test-db.ts
new file mode 100644
index 00000000..7ff1a507
--- /dev/null
+++ b/src/__tests__/utils/phase01-test-db.ts
@@ -0,0 +1,1222 @@
+import { randomUUID } from "crypto";
+import fs from "fs";
+import os from "os";
+import path from "path";
+
+import type { ActorContext } from "@/lib/db/with-actor";
+
+type SQLiteStatement = {
+  all: (...args: unknown[]) => unknown[];
+  get: (...args: unknown[]) => unknown;
+  run: (...args: unknown[]) => unknown;
+};
+
+type SQLiteDatabase = {
+  close: () => void;
+  exec: (sql: string) => void;
+  function: (name: string, fn: (...args: unknown[]) => unknown) => void;
+  prepare: (sql: string) => SQLiteStatement;
+};
+
+const { DatabaseSync } = require("node:sqlite") as {
+  DatabaseSync: new (location: string) => SQLiteDatabase;
+};
+
+type Row = Record<string, unknown>;
+
+interface TxContext {
+  actorSettings: Map<string, string>;
+  lockTimeoutMs: number;
+  ownedLocks: Set<string>;
+}
+
+interface TestTx {
+  __phase01: {
+    db: SQLiteDatabase;
+    context: TxContext;
+  };
+  $executeRawUnsafe: (sql: string) => Promise<number>;
+  $executeRaw: (
+    strings: TemplateStringsArray,
+    ...values: unknown[]
+  ) => Promise<number>;
+  $queryRaw: <T>(
+    strings: TemplateStringsArray,
+    ...values: unknown[]
+  ) => Promise<T>;
+  physicalUnit: {
+    upsert: (args: {
+      where: {
+        canonicalAddressHash_canonicalUnit: {
+          canonicalAddressHash: string;
+          canonicalUnit: string;
+        };
+      };
+      create: {
+        canonicalAddressHash: string;
+        canonicalUnit: string;
+        canonicalizerVersion: string;
+      };
+      update: {
+        canonicalizerVersion: string;
+        sourceVersion: { increment: bigint };
+        rowVersion: { increment: bigint };
+      };
+      select: {
+        id: boolean;
+        unitIdentityEpoch: boolean;
+        sourceVersion: boolean;
+      };
+    }) => Promise<{
+      id: string;
+      unitIdentityEpoch: number;
+      sourceVersion: bigint;
+    }>;
+    findMany: (args: {
+      where: { id: { in: string[] } };
+      select: {
+        id: boolean;
+        unitIdentityEpoch: boolean;
+        supersedesUnitIds: boolean;
+      };
+    }) => Promise<
+      Array<{
+        id: string;
+        unitIdentityEpoch: number;
+        supersedesUnitIds: string[];
+      }>
+    >;
+    update: (args: {
+      where: { id: string };
+      data: Record<string, unknown>;
+    }) => Promise<void>;
+  };
+  hostUnitClaim: {
+    create: (args: { data: Record<string, unknown> }) => Promise<{ id: string }>;
+    update: (args: {
+      where: { id: string };
+      data: Record<string, unknown>;
+    }) => Promise<void>;
+  };
+  listingInventory: {
+    create: (args: { data: Record<string, unknown> }) => Promise<{ id: string }>;
+    update: (args: {
+      where: { id: string };
+      data: Record<string, unknown>;
+    }) => Promise<void>;
+  };
+  identityMutation: {
+    create: (args: {
+      data: Record<string, unknown>;
+      select: { id: boolean };
+    }) => Promise<{ id: string }>;
+  };
+  outboxEvent: {
+    create: (args: {
+      data: Record<string, unknown>;
+      select: { id: boolean };
+    }) => Promise<{ id: string }>;
+  };
+  auditEvent: {
+    create: (args: {
+      data: Record<string, unknown>;
+      select: { id: boolean };
+    }) => Promise<{ id: string }>;
+  };
+}
+
+type TransactionHost = {
+  $transaction: <T>(
+    fnOrArray: ((tx: TestTx) => Promise<T>) | Promise<T>[],
+    _options?: Record<string, unknown>
+  ) => Promise<T>;
+};
+
+const RANGE_LITERAL =
+  /^[[(]\d{4}-\d{2}-\d{2}T[^,]+,\d{4}-\d{2}-\d{2}T.+[)\]]$/;
+
+function toDbScalar(value: unknown): unknown {
+  if (typeof value === "bigint") {
+    return Number(value);
+  }
+  if (Array.isArray(value) || (value && typeof value === "object")) {
+    return JSON.stringify(value);
+  }
+  if (typeof value === "boolean") {
+    return value ? 1 : 0;
+  }
+  return value ?? null;
+}
+
+function hasOwn(object: object, key: string): boolean {
+  return Object.prototype.hasOwnProperty.call(object, key);
+}
+
+function fromJsonArray(value: unknown): string[] {
+  if (typeof value !== "string" || value.length === 0) {
+    return [];
+  }
+  return JSON.parse(value) as string[];
+}
+
+function fromJsonValue<T>(value: unknown): T {
+  if (typeof value !== "string") {
+    return value as T;
+  }
+  return JSON.parse(value) as T;
+}
+
+function readBigInt(value: unknown): bigint {
+  if (typeof value === "bigint") {
+    return value;
+  }
+  return BigInt(Number(value ?? 0));
+}
+
+function createContext(): TxContext {
+  return {
+    actorSettings: new Map(),
+    lockTimeoutMs: 5000,
+    ownedLocks: new Set(),
+  };
+}
+
+function addBigInt(rows: Row[]): Row[] {
+  return rows.map((row) => {
+    const next = { ...row };
+    for (const key of [
+      "source_version",
+      "row_version",
+      "projection_epoch",
+      "unit_identity_epoch",
+      "unit_identity_epoch_written_at",
+      "resulting_epoch",
+      "priority",
+    ]) {
+      if (key in next && typeof next[key] === "number") {
+        next[key] = BigInt(next[key] as number);
+      }
+    }
+    return next;
+  });
+}
+
+class AdvisoryLockManager {
+  private owners = new Map<string, string>();
+  private waiters = new Map<string, Array<() => void>>();
+
+  async acquire(key: string, txId: string): Promise<void> {
+    if (this.owners.get(key) === txId) {
+      return;
+    }
+
+    if (!this.owners.has(key)) {
+      this.owners.set(key, txId);
+      return;
+    }
+
+    await new Promise<void>((resolve) => {
+      const queue = this.waiters.get(key) ?? [];
+      queue.push(resolve);
+      this.waiters.set(key, queue);
+    });
+
+    this.owners.set(key, txId);
+  }
+
+  releaseAll(txId: string): void {
+    for (const [key, owner] of this.owners.entries()) {
+      if (owner !== txId) {
+        continue;
+      }
+
+      const queue = this.waiters.get(key) ?? [];
+      const next = queue.shift();
+      if (next) {
+        this.waiters.set(key, queue);
+        next();
+      } else {
+        this.owners.delete(key);
+        this.waiters.delete(key);
+      }
+    }
+  }
+}
+
+class TransactionQueue {
+  private tail = Promise.resolve();
+
+  async run<T>(fn: () => Promise<T>): Promise<T> {
+    const previous = this.tail;
+    let release = () => {};
+    this.tail = new Promise<void>((resolve) => {
+      release = resolve;
+    });
+
+    await previous;
+    try {
+      return await fn();
+    } finally {
+      release();
+    }
+  }
+}
+
+function registerFunctions(db: SQLiteDatabase, context: TxContext | null): void {
+  db.function("gen_random_uuid", () => randomUUID());
+  db.function("set_config", (name: unknown, value: unknown) => {
+    if (context) {
+      context.actorSettings.set(String(name), value == null ? "" : String(value));
+    }
+    return value ?? "";
+  });
+  db.function("current_setting", (name: unknown) => {
+    if (!context) {
+      return null;
+    }
+    return context.actorSettings.get(String(name)) ?? null;
+  });
+  db.function("hashtext", (value: unknown) => String(value ?? ""));
+  db.function("is_valid_tstzrange", (value: unknown) =>
+    RANGE_LITERAL.test(String(value ?? "")) ? 1 : 0
+  );
+}
+
+function prepare(db: SQLiteDatabase, sql: string) {
+  return db.prepare(sql);
+}
+
+function buildInsert(
+  db: SQLiteDatabase,
+  table: string,
+  data: Record<string, unknown>,
+  returnId = true
+): { id: string } {
+  const id = String(data.id ?? randomUUID());
+  const fullData: Record<string, unknown> = { ...data, id };
+  const columns = Object.keys(fullData);
+  const placeholders = columns.map(() => "?").join(", ");
+  prepare(
+    db,
+    `INSERT INTO "${table}" (${columns
+      .map((column) => `"${column}"`)
+      .join(", ")}) VALUES (${placeholders})`
+  ).run(...columns.map((column) => toDbScalar(fullData[column])));
+
+  return returnId ? { id } : { id: "" };
+}
+
+function buildUpdate(
+  db: SQLiteDatabase,
+  table: string,
+  id: string,
+  data: Record<string, unknown>
+) {
+  const assignments: string[] = [];
+  const values: unknown[] = [];
+
+  for (const [column, rawValue] of Object.entries(data)) {
+    if (
+      rawValue &&
+      typeof rawValue === "object" &&
+      "increment" in (rawValue as { increment?: unknown })
+    ) {
+      assignments.push(`"${column}" = "${column}" + ?`);
+      values.push(
+        Number((rawValue as { increment: bigint }).increment)
+      );
+      continue;
+    }
+
+    assignments.push(`"${column}" = ?`);
+    values.push(toDbScalar(rawValue));
+  }
+
+  if (
+    !Object.prototype.hasOwnProperty.call(data, "updated_at") &&
+    ["physical_units", "host_unit_claims", "listing_inventories"].includes(table)
+  ) {
+    assignments.push(`"updated_at" = CURRENT_TIMESTAMP`);
+  }
+
+  prepare(
+    db,
+    `UPDATE "${table}" SET ${assignments.join(", ")} WHERE id = ?`
+  ).run(...values, id);
+}
+
+function rawQuery(db: SQLiteDatabase, sql: string, values: unknown[] = []): Row[] {
+  return addBigInt(prepare(db, sql).all(...values.map(toDbScalar)) as Row[]);
+}
+
+function normalizeSql(strings: TemplateStringsArray): string {
+  return strings.join("?");
+}
+
+function createTransactionClient(
+  db: SQLiteDatabase,
+  context: TxContext,
+  txId: string,
+  locks: AdvisoryLockManager
+): TestTx {
+  const tx: TestTx = {
+    __phase01: {
+      db,
+      context,
+    },
+    async $executeRawUnsafe(sql: string) {
+      if (sql.includes("SET LOCAL lock_timeout")) {
+        context.lockTimeoutMs = 5000;
+        return 0;
+      }
+
+      prepare(db, sql).run();
+      return 0;
+    },
+    async $executeRaw(strings, ...values) {
+      const sql = normalizeSql(strings);
+
+      if (sql.includes("set_config('app.actor_role'")) {
+        context.actorSettings.set("app.actor_role", String(values[0] ?? ""));
+        return 1;
+      }
+
+      if (sql.includes("set_config('app.actor_id'")) {
+        context.actorSettings.set("app.actor_id", String(values[0] ?? ""));
+        return 1;
+      }
+
+      if (sql.includes("SELECT pg_advisory_xact_lock(hashtext(")) {
+        const key = String(values[0] ?? "");
+        await locks.acquire(key, txId);
+        context.ownedLocks.add(key);
+        return 1;
+      }
+
+      if (sql.includes('INSERT INTO "IdempotencyKey"')) {
+        prepare(
+          db,
+          `INSERT INTO "IdempotencyKey" (
+            id, key, "userId", endpoint, status, "requestHash", "createdAt", "expiresAt"
+          )
+          VALUES (?, ?, ?, ?, 'processing', ?, CURRENT_TIMESTAMP, datetime(CURRENT_TIMESTAMP, '+24 hours'))
+          ON CONFLICT ("userId", endpoint, key) DO NOTHING`
+        ).run(randomUUID(), values[0], values[1], values[2], values[3]);
+        return 1;
+      }
+
+      if (sql.includes('UPDATE "IdempotencyKey"') && sql.includes("SET status = 'completed'")) {
+        prepare(
+          db,
+          `UPDATE "IdempotencyKey"
+           SET status = 'completed',
+               "requestHash" = ?,
+               "resultData" = ?
+           WHERE id = ?`
+        ).run(values[0], values[1], values[2]);
+        return 1;
+      }
+
+      throw new Error(`Unsupported $executeRaw SQL in Phase 01 test harness: ${sql}`);
+    },
+    async $queryRaw(strings, ...values) {
+      const sql = normalizeSql(strings);
+
+      if (sql.includes('FROM "IdempotencyKey"') && sql.includes("FOR UPDATE")) {
+        return rawQuery(
+          db,
+          `SELECT id, status, "requestHash", "resultData"
+           FROM "IdempotencyKey"
+           WHERE "userId" = ?
+             AND endpoint = ?
+             AND key = ?`,
+          values
+        ) as never;
+      }
+
+      throw new Error(`Unsupported $queryRaw SQL in Phase 01 test harness: ${sql}`);
+    },
+    physicalUnit: {
+      async upsert(args) {
+        const existing = prepare(
+          db,
+          `SELECT id, unit_identity_epoch, source_version
+           FROM physical_units
+           WHERE canonical_address_hash = ?
+             AND canonical_unit = ?`
+        ).get(
+          args.where.canonicalAddressHash_canonicalUnit.canonicalAddressHash,
+          args.where.canonicalAddressHash_canonicalUnit.canonicalUnit
+        ) as Row | undefined;
+
+        if (!existing) {
+          const createdId = randomUUID();
+          prepare(
+            db,
+            `INSERT INTO physical_units (
+              id,
+              canonical_address_hash,
+              canonical_unit,
+              canonicalizer_version
+            )
+            VALUES (?, ?, ?, ?)`
+          ).run(
+            createdId,
+            args.create.canonicalAddressHash,
+            args.create.canonicalUnit,
+            args.create.canonicalizerVersion
+          );
+
+          return {
+            id: createdId,
+            unitIdentityEpoch: 1,
+            sourceVersion: BigInt(1),
+          };
+        }
+
+        prepare(
+          db,
+          `UPDATE physical_units
+           SET canonicalizer_version = ?,
+               source_version = source_version + 1,
+               row_version = row_version + 1,
+               updated_at = CURRENT_TIMESTAMP
+           WHERE id = ?`
+        ).run(args.update.canonicalizerVersion, existing.id);
+
+        const updated = prepare(
+          db,
+          `SELECT id, unit_identity_epoch, source_version
+           FROM physical_units
+           WHERE id = ?`
+        ).get(existing.id) as Row;
+
+        return {
+          id: String(updated.id),
+          unitIdentityEpoch: Number(updated.unit_identity_epoch),
+          sourceVersion: readBigInt(updated.source_version),
+        };
+      },
+      async findMany(args) {
+        const placeholders = args.where.id.in.map(() => "?").join(", ");
+        return rawQuery(
+          db,
+          `SELECT id, unit_identity_epoch, supersedes_unit_ids
+           FROM physical_units
+           WHERE id IN (${placeholders})`,
+          args.where.id.in
+        ).map((row) => ({
+          id: String(row.id),
+          unitIdentityEpoch: Number(row.unit_identity_epoch),
+          supersedesUnitIds: fromJsonArray(row.supersedes_unit_ids),
+        }));
+      },
+      async update(args) {
+        const passthrough = Object.fromEntries(
+          Object.entries(args.data).filter(
+            ([key]) =>
+              ![
+                "unitIdentityEpoch",
+                "sourceVersion",
+                "rowVersion",
+                "supersedesUnitIds",
+                "supersededByUnitId",
+              ].includes(key)
+          )
+        );
+
+        buildUpdate(db, "physical_units", args.where.id, {
+          ...passthrough,
+          ...(args.data.unitIdentityEpoch !== undefined
+            ? { unit_identity_epoch: args.data.unitIdentityEpoch }
+            : {}),
+          ...(args.data.sourceVersion !== undefined
+            ? { source_version: args.data.sourceVersion }
+            : {}),
+          ...(args.data.rowVersion !== undefined
+            ? { row_version: args.data.rowVersion }
+            : {}),
+          ...(args.data.supersedesUnitIds !== undefined
+            ? { supersedes_unit_ids: args.data.supersedesUnitIds }
+            : {}),
+          ...(args.data.supersededByUnitId !== undefined
+            ? { superseded_by_unit_id: args.data.supersededByUnitId }
+            : {}),
+        });
+      },
+    },
+    hostUnitClaim: {
+      async create(args) {
