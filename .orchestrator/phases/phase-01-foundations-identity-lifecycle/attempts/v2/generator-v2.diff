+
+  getOutboxEvents(): Array<{
+    id: string;
+    aggregateType: string;
+    aggregateId: string;
+    kind: string;
+    payload: Record<string, unknown>;
+    priority: number;
+    unitIdentityEpoch: number;
+  }> {
+    return rawQuery(
+      this.baseDb,
+      `SELECT id,
+              aggregate_type,
+              aggregate_id,
+              kind,
+              payload,
+              priority,
+              unit_identity_epoch
+       FROM outbox_events
+       ORDER BY created_at`
+    ).map((row) => ({
+      id: String(row.id),
+      aggregateType: String(row.aggregate_type),
+      aggregateId: String(row.aggregate_id),
+      kind: String(row.kind),
+      payload: fromJsonValue<Record<string, unknown>>(row.payload),
+      priority: Number(row.priority),
+      unitIdentityEpoch: Number(row.unit_identity_epoch),
+    }));
+  }
+}
+
+export function hostActor(id = "host-1"): ActorContext {
+  return { role: "host", id };
+}
+
+export function moderatorActor(id = "moderator-1"): ActorContext {
+  return { role: "moderator", id };
+}
+
+export function systemActor(id: string | null = null): ActorContext {
+  return { role: "system", id };
+}
