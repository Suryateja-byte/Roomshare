diff --git a/src/lib/identity/mutate-unit.ts b/src/lib/identity/mutate-unit.ts
new file mode 100644
index 00000000..520ecb0d
--- /dev/null
+++ b/src/lib/identity/mutate-unit.ts
@@ -0,0 +1,203 @@
+import { z } from "zod";
+import type { TransactionClient } from "@/lib/db/with-actor";
+import { recordAuditEvent } from "@/lib/audit/events";
+import { appendOutboxEvent } from "@/lib/outbox/append";
+import {
+  acquireXactLock,
+  identityMutationLockKey,
+} from "@/lib/identity/advisory-locks";
+
+export type IdentityMutationKind =
+  | "MERGE"
+  | "SPLIT"
+  | "CANONICALIZER_UPGRADE"
+  | "MANUAL_MODERATION";
+
+export interface IdentityMutationInput {
+  kind: IdentityMutationKind;
+  fromUnitIds: string[];
+  toUnitIds: string[];
+  reasonCode: string;
+  operatorId: string | null;
+}
+
+export interface IdentityMutationResult {
+  mutationId: string;
+  resultingEpoch: number;
+  affectedUnitIds: string[];
+}
+
+const ALLOWED_REASON_CODES = [
+  "operator_duplicate",
+  "operator_split",
+  "operator_reconcile",
+  "canonicalizer_upgrade",
+  "manual_moderation",
+  "moderation_review",
+  "system_reconcile",
+] as const;
+
+const IdentityMutationInputSchema = z.object({
+  kind: z.enum([
+    "MERGE",
+    "SPLIT",
+    "CANONICALIZER_UPGRADE",
+    "MANUAL_MODERATION",
+  ]),
+  fromUnitIds: z.array(z.string().trim().min(1)).min(1),
+  toUnitIds: z.array(z.string().trim().min(1)).min(1),
+  reasonCode: z.enum(ALLOWED_REASON_CODES),
+  operatorId: z.string().trim().min(1).nullable(),
+}).superRefine((value, ctx) => {
+  if (value.kind === "MERGE" && value.toUnitIds.length !== 1) {
+    ctx.addIssue({
+      code: z.ZodIssueCode.custom,
+      path: ["toUnitIds"],
+      message: "MERGE requires exactly one target unit id",
+    });
+  }
+
+  if (value.kind === "SPLIT" && value.fromUnitIds.length !== 1) {
+    ctx.addIssue({
+      code: z.ZodIssueCode.custom,
+      path: ["fromUnitIds"],
+      message: "SPLIT requires exactly one source unit id",
+    });
+  }
+});
+
+function uniq(values: string[]): string[] {
+  return Array.from(new Set(values));
+}
+
+function dedupeSupersedes(existing: string[], incoming: string[]): string[] {
+  return uniq([...existing, ...incoming]);
+}
+
+export async function recordIdentityMutation(
+  tx: TransactionClient,
+  input: IdentityMutationInput
+): Promise<IdentityMutationResult> {
+  const parsed = IdentityMutationInputSchema.parse({
+    ...input,
+    fromUnitIds: uniq(input.fromUnitIds),
+    toUnitIds: uniq(input.toUnitIds),
+  });
+
+  const affectedUnitIds = uniq([...parsed.fromUnitIds, ...parsed.toUnitIds]).sort();
+  for (const unitId of affectedUnitIds) {
+    await acquireXactLock(tx, identityMutationLockKey(unitId));
+  }
+
+  const units = await tx.physicalUnit.findMany({
+    where: { id: { in: affectedUnitIds } },
+    select: {
+      id: true,
+      unitIdentityEpoch: true,
+      supersedesUnitIds: true,
+    },
+  });
+
+  const foundIds = new Set(units.map((unit) => unit.id));
+  for (const unitId of affectedUnitIds) {
+    if (!foundIds.has(unitId)) {
+      throw new Error(`Unknown physical unit: ${unitId}`);
+    }
+  }
+
+  const resultingEpoch =
+    Math.max(...units.map((unit) => unit.unitIdentityEpoch), 0) + 1;
+
+  const mutation = await tx.identityMutation.create({
+    data: {
+      kind: parsed.kind,
+      fromUnitIds: parsed.fromUnitIds,
+      toUnitIds: parsed.toUnitIds,
+      reasonCode: parsed.reasonCode,
+      operatorId: parsed.operatorId,
+      resultingEpoch,
+    },
+    select: { id: true },
+  });
+
+  const unitById = new Map(units.map((unit) => [unit.id, unit]));
+
+  for (const unitId of affectedUnitIds) {
+    const current = unitById.get(unitId);
+    if (!current) {
+      continue;
+    }
+
+    const data: {
+      unitIdentityEpoch: number;
+      sourceVersion: { increment: bigint };
+      rowVersion: { increment: bigint };
+      supersededByUnitId?: string | null;
+      supersedesUnitIds?: string[];
+    } = {
+      unitIdentityEpoch: resultingEpoch,
+      sourceVersion: { increment: BigInt(1) },
+      rowVersion: { increment: BigInt(1) },
+    };
+
+    if (parsed.kind === "MERGE" && parsed.toUnitIds.length === 1) {
+      if (parsed.fromUnitIds.includes(unitId)) {
+        data.supersededByUnitId = parsed.toUnitIds[0];
+      }
+      if (parsed.toUnitIds.includes(unitId)) {
+        data.supersedesUnitIds = dedupeSupersedes(
+          current.supersedesUnitIds,
+          parsed.fromUnitIds
+        );
+      }
+    }
+
+    if (parsed.kind === "SPLIT" && parsed.toUnitIds.includes(unitId)) {
+      data.supersedesUnitIds = dedupeSupersedes(
+        current.supersedesUnitIds,
+        parsed.fromUnitIds
+      );
+    }
+
+    await tx.physicalUnit.update({
+      where: { id: unitId },
+      data,
+    });
+  }
+
+  await appendOutboxEvent(tx, {
+    aggregateType: "IDENTITY_MUTATION",
+    aggregateId: mutation.id,
+    kind: "IDENTITY_MUTATION",
+    payload: {
+      kind: parsed.kind,
+      fromUnitIds: parsed.fromUnitIds,
+      toUnitIds: parsed.toUnitIds,
+      reasonCode: parsed.reasonCode,
+    },
+    sourceVersion: BigInt(1),
+    unitIdentityEpoch: resultingEpoch,
+    priority: 0,
+  });
+
+  await recordAuditEvent(tx, {
+    kind: "IDENTITY_MUTATION",
+    actor: {
+      role: parsed.operatorId ? "moderator" : "system",
+      id: parsed.operatorId,
+    },
+    aggregateType: "identity_mutations",
+    aggregateId: mutation.id,
+    unitIdentityEpoch: resultingEpoch,
+    details: {
+      affectedUnitCount: affectedUnitIds.length,
+      reasonCode: parsed.reasonCode,
+    },
+  });
+
+  return {
+    mutationId: mutation.id,
+    resultingEpoch,
+    affectedUnitIds,
+  };
+}
diff --git a/src/lib/identity/resolve-or-create-unit.ts b/src/lib/identity/resolve-or-create-unit.ts
new file mode 100644
index 00000000..8f2f84ab
--- /dev/null
+++ b/src/lib/identity/resolve-or-create-unit.ts
@@ -0,0 +1,106 @@
+import type { TransactionClient } from "@/lib/db/with-actor";
+import { setActorContext } from "@/lib/db/with-actor";
+import { appendOutboxEvent } from "@/lib/outbox/append";
+import { recordAuditEvent } from "@/lib/audit/events";
+import {
+  acquireXactLock,
+  canonicalUnitLockKey,
+} from "@/lib/identity/advisory-locks";
+import {
+  canonicalizeAddress,
+  type RawAddressInput,
+} from "@/lib/identity/canonical-address";
+
+export interface ResolveOrCreateUnitInput {
+  address: RawAddressInput;
+  actor: { role: "host" | "moderator" | "system"; id: string | null };
+  requestId?: string;
+}
+
+export interface ResolveOrCreateUnitResult {
+  unitId: string;
+  unitIdentityEpoch: number;
+  created: boolean;
+  canonicalAddressHash: string;
+}
+
+/**
+ * Resolve or create the canonical physical_units row for the given address.
+ */
+export async function resolveOrCreateUnit(
+  tx: TransactionClient,
+  input: ResolveOrCreateUnitInput
+): Promise<ResolveOrCreateUnitResult> {
+  // Defensive guard: callers are expected to use withActor(), but keeping the
+  // local set_config calls here preserves the actor context for direct tx users.
+  await setActorContext(tx, input.actor);
+
+  const canonical = canonicalizeAddress(input.address);
+  await acquireXactLock(
+    tx,
+    canonicalUnitLockKey(canonical.canonicalAddressHash)
+  );
+
+  const unit = await tx.physicalUnit.upsert({
+    where: {
+      canonicalAddressHash_canonicalUnit: {
+        canonicalAddressHash: canonical.canonicalAddressHash,
+        canonicalUnit: canonical.canonicalUnit,
+      },
+    },
+    create: {
+      canonicalAddressHash: canonical.canonicalAddressHash,
+      canonicalUnit: canonical.canonicalUnit,
+      canonicalizerVersion: canonical.canonicalizerVersion,
+    },
+    update: {
+      canonicalizerVersion: canonical.canonicalizerVersion,
+      sourceVersion: { increment: BigInt(1) },
+      rowVersion: { increment: BigInt(1) },
+    },
+    select: {
+      id: true,
+      unitIdentityEpoch: true,
+      sourceVersion: true,
+    },
+  });
+
+  // Prisma upsert does not expose Postgres xmax, so the created flag relies on
+  // the invariant that inserts start at sourceVersion=1 and every update path
+  // increments it before returning.
+  const created = unit.sourceVersion === BigInt(1);
+
+  await appendOutboxEvent(tx, {
+    aggregateType: "PHYSICAL_UNIT",
+    aggregateId: unit.id,
+    kind: "UNIT_UPSERTED",
+    payload: {
+      canonicalAddressHash: canonical.canonicalAddressHash,
+      canonicalUnit: canonical.canonicalUnit,
+      created,
+      requestId: input.requestId ?? null,
+    },
+    sourceVersion: unit.sourceVersion,
+    unitIdentityEpoch: unit.unitIdentityEpoch,
+  });
+
+  await recordAuditEvent(tx, {
+    kind: created ? "CANONICAL_UNIT_CREATED" : "CANONICAL_UNIT_RESOLVED",
+    actor: input.actor,
+    aggregateType: "physical_units",
+    aggregateId: unit.id,
+    requestId: input.requestId,
+    unitIdentityEpoch: unit.unitIdentityEpoch,
+    details: {
+      created,
+      canonicalizerVersion: canonical.canonicalizerVersion,
+    },
+  });
+
+  return {
+    unitId: unit.id,
+    unitIdentityEpoch: unit.unitIdentityEpoch,
+    created,
+    canonicalAddressHash: canonical.canonicalAddressHash,
+  };
+}
diff --git a/src/__tests__/utils/phase01-test-db.ts b/src/__tests__/utils/phase01-test-db.ts
new file mode 100644
index 00000000..7ff1a507
--- /dev/null
+++ b/src/__tests__/utils/phase01-test-db.ts
@@ -0,0 +1,1222 @@
+import { randomUUID } from "crypto";
+import fs from "fs";
+import os from "os";
+import path from "path";
+
+import type { ActorContext } from "@/lib/db/with-actor";
+
+type SQLiteStatement = {
+  all: (...args: unknown[]) => unknown[];
+  get: (...args: unknown[]) => unknown;
+  run: (...args: unknown[]) => unknown;
+};
+
+type SQLiteDatabase = {
+  close: () => void;
+  exec: (sql: string) => void;
+  function: (name: string, fn: (...args: unknown[]) => unknown) => void;
+  prepare: (sql: string) => SQLiteStatement;
+};
+
+const { DatabaseSync } = require("node:sqlite") as {
+  DatabaseSync: new (location: string) => SQLiteDatabase;
+};
+
+type Row = Record<string, unknown>;
+
+interface TxContext {
+  actorSettings: Map<string, string>;
+  lockTimeoutMs: number;
+  ownedLocks: Set<string>;
+}
+
+interface TestTx {
+  __phase01: {
+    db: SQLiteDatabase;
+    context: TxContext;
+  };
+  $executeRawUnsafe: (sql: string) => Promise<number>;
+  $executeRaw: (
+    strings: TemplateStringsArray,
+    ...values: unknown[]
+  ) => Promise<number>;
+  $queryRaw: <T>(
+    strings: TemplateStringsArray,
+    ...values: unknown[]
+  ) => Promise<T>;
+  physicalUnit: {
+    upsert: (args: {
+      where: {
+        canonicalAddressHash_canonicalUnit: {
+          canonicalAddressHash: string;
+          canonicalUnit: string;
+        };
+      };
+      create: {
+        canonicalAddressHash: string;
+        canonicalUnit: string;
+        canonicalizerVersion: string;
+      };
+      update: {
+        canonicalizerVersion: string;
+        sourceVersion: { increment: bigint };
+        rowVersion: { increment: bigint };
+      };
+      select: {
+        id: boolean;
+        unitIdentityEpoch: boolean;
+        sourceVersion: boolean;
+      };
+    }) => Promise<{
+      id: string;
+      unitIdentityEpoch: number;
+      sourceVersion: bigint;
+    }>;
+    findMany: (args: {
+      where: { id: { in: string[] } };
+      select: {
+        id: boolean;
+        unitIdentityEpoch: boolean;
+        supersedesUnitIds: boolean;
+      };
+    }) => Promise<
+      Array<{
+        id: string;
+        unitIdentityEpoch: number;
+        supersedesUnitIds: string[];
+      }>
+    >;
+    update: (args: {
+      where: { id: string };
+      data: Record<string, unknown>;
+    }) => Promise<void>;
+  };
+  hostUnitClaim: {
+    create: (args: { data: Record<string, unknown> }) => Promise<{ id: string }>;
+    update: (args: {
+      where: { id: string };
+      data: Record<string, unknown>;
+    }) => Promise<void>;
+  };
+  listingInventory: {
+    create: (args: { data: Record<string, unknown> }) => Promise<{ id: string }>;
+    update: (args: {
+      where: { id: string };
+      data: Record<string, unknown>;
+    }) => Promise<void>;
+  };
+  identityMutation: {
+    create: (args: {
+      data: Record<string, unknown>;
+      select: { id: boolean };
+    }) => Promise<{ id: string }>;
+  };
+  outboxEvent: {
+    create: (args: {
+      data: Record<string, unknown>;
+      select: { id: boolean };
+    }) => Promise<{ id: string }>;
+  };
+  auditEvent: {
+    create: (args: {
+      data: Record<string, unknown>;
+      select: { id: boolean };
+    }) => Promise<{ id: string }>;
+  };
+}
+
+type TransactionHost = {
+  $transaction: <T>(
+    fnOrArray: ((tx: TestTx) => Promise<T>) | Promise<T>[],
+    _options?: Record<string, unknown>
+  ) => Promise<T>;
+};
+
+const RANGE_LITERAL =
+  /^[[(]\d{4}-\d{2}-\d{2}T[^,]+,\d{4}-\d{2}-\d{2}T.+[)\]]$/;
+
+function toDbScalar(value: unknown): unknown {
+  if (typeof value === "bigint") {
+    return Number(value);
+  }
+  if (Array.isArray(value) || (value && typeof value === "object")) {
+    return JSON.stringify(value);
+  }
+  if (typeof value === "boolean") {
+    return value ? 1 : 0;
+  }
+  return value ?? null;
+}
+
+function hasOwn(object: object, key: string): boolean {
+  return Object.prototype.hasOwnProperty.call(object, key);
+}
+
+function fromJsonArray(value: unknown): string[] {
+  if (typeof value !== "string" || value.length === 0) {
+    return [];
+  }
+  return JSON.parse(value) as string[];
+}
+
+function fromJsonValue<T>(value: unknown): T {
+  if (typeof value !== "string") {
+    return value as T;
+  }
+  return JSON.parse(value) as T;
+}
+
+function readBigInt(value: unknown): bigint {
+  if (typeof value === "bigint") {
+    return value;
+  }
+  return BigInt(Number(value ?? 0));
+}
+
+function createContext(): TxContext {
+  return {
+    actorSettings: new Map(),
+    lockTimeoutMs: 5000,
+    ownedLocks: new Set(),
+  };
+}
+
+function addBigInt(rows: Row[]): Row[] {
+  return rows.map((row) => {
+    const next = { ...row };
+    for (const key of [
+      "source_version",
+      "row_version",
+      "projection_epoch",
+      "unit_identity_epoch",
+      "unit_identity_epoch_written_at",
+      "resulting_epoch",
+      "priority",
+    ]) {
+      if (key in next && typeof next[key] === "number") {
+        next[key] = BigInt(next[key] as number);
+      }
+    }
+    return next;
+  });
+}
+
+class AdvisoryLockManager {
+  private owners = new Map<string, string>();
+  private waiters = new Map<string, Array<() => void>>();
+
+  async acquire(key: string, txId: string): Promise<void> {
+    if (this.owners.get(key) === txId) {
+      return;
+    }
+
+    if (!this.owners.has(key)) {
+      this.owners.set(key, txId);
+      return;
+    }
+
+    await new Promise<void>((resolve) => {
+      const queue = this.waiters.get(key) ?? [];
+      queue.push(resolve);
+      this.waiters.set(key, queue);
+    });
+
+    this.owners.set(key, txId);
+  }
+
+  releaseAll(txId: string): void {
+    for (const [key, owner] of this.owners.entries()) {
+      if (owner !== txId) {
+        continue;
+      }
+
+      const queue = this.waiters.get(key) ?? [];
+      const next = queue.shift();
+      if (next) {
+        this.waiters.set(key, queue);
+        next();
+      } else {
+        this.owners.delete(key);
+        this.waiters.delete(key);
+      }
+    }
+  }
+}
+
+class TransactionQueue {
+  private tail = Promise.resolve();
+
+  async run<T>(fn: () => Promise<T>): Promise<T> {
+    const previous = this.tail;
+    let release = () => {};
+    this.tail = new Promise<void>((resolve) => {
+      release = resolve;
+    });
+
+    await previous;
+    try {
+      return await fn();
+    } finally {
+      release();
+    }
+  }
+}
+
+function registerFunctions(db: SQLiteDatabase, context: TxContext | null): void {
+  db.function("gen_random_uuid", () => randomUUID());
+  db.function("set_config", (name: unknown, value: unknown) => {
+    if (context) {
+      context.actorSettings.set(String(name), value == null ? "" : String(value));
+    }
+    return value ?? "";
+  });
+  db.function("current_setting", (name: unknown) => {
+    if (!context) {
+      return null;
+    }
+    return context.actorSettings.get(String(name)) ?? null;
+  });
+  db.function("hashtext", (value: unknown) => String(value ?? ""));
+  db.function("is_valid_tstzrange", (value: unknown) =>
+    RANGE_LITERAL.test(String(value ?? "")) ? 1 : 0
+  );
+}
+
+function prepare(db: SQLiteDatabase, sql: string) {
+  return db.prepare(sql);
+}
+
+function buildInsert(
+  db: SQLiteDatabase,
+  table: string,
+  data: Record<string, unknown>,
+  returnId = true
+): { id: string } {
+  const id = String(data.id ?? randomUUID());
+  const fullData: Record<string, unknown> = { ...data, id };
+  const columns = Object.keys(fullData);
+  const placeholders = columns.map(() => "?").join(", ");
+  prepare(
+    db,
+    `INSERT INTO "${table}" (${columns
+      .map((column) => `"${column}"`)
+      .join(", ")}) VALUES (${placeholders})`
+  ).run(...columns.map((column) => toDbScalar(fullData[column])));
+
+  return returnId ? { id } : { id: "" };
+}
+
+function buildUpdate(
+  db: SQLiteDatabase,
+  table: string,
+  id: string,
+  data: Record<string, unknown>
+) {
+  const assignments: string[] = [];
+  const values: unknown[] = [];
+
+  for (const [column, rawValue] of Object.entries(data)) {
+    if (
+      rawValue &&
+      typeof rawValue === "object" &&
+      "increment" in (rawValue as { increment?: unknown })
+    ) {
+      assignments.push(`"${column}" = "${column}" + ?`);
+      values.push(
+        Number((rawValue as { increment: bigint }).increment)
+      );
+      continue;
+    }
+
+    assignments.push(`"${column}" = ?`);
+    values.push(toDbScalar(rawValue));
+  }
+
+  if (
+    !Object.prototype.hasOwnProperty.call(data, "updated_at") &&
+    ["physical_units", "host_unit_claims", "listing_inventories"].includes(table)
+  ) {
+    assignments.push(`"updated_at" = CURRENT_TIMESTAMP`);
+  }
+
+  prepare(
+    db,
+    `UPDATE "${table}" SET ${assignments.join(", ")} WHERE id = ?`
+  ).run(...values, id);
+}
+
+function rawQuery(db: SQLiteDatabase, sql: string, values: unknown[] = []): Row[] {
+  return addBigInt(prepare(db, sql).all(...values.map(toDbScalar)) as Row[]);
+}
+
+function normalizeSql(strings: TemplateStringsArray): string {
+  return strings.join("?");
+}
+
+function createTransactionClient(
+  db: SQLiteDatabase,
+  context: TxContext,
+  txId: string,
+  locks: AdvisoryLockManager
+): TestTx {
+  const tx: TestTx = {
+    __phase01: {
+      db,
+      context,
+    },
+    async $executeRawUnsafe(sql: string) {
+      if (sql.includes("SET LOCAL lock_timeout")) {
+        context.lockTimeoutMs = 5000;
+        return 0;
+      }
+
+      prepare(db, sql).run();
+      return 0;
+    },
+    async $executeRaw(strings, ...values) {
+      const sql = normalizeSql(strings);
+
+      if (sql.includes("set_config('app.actor_role'")) {
+        context.actorSettings.set("app.actor_role", String(values[0] ?? ""));
+        return 1;
+      }
+
+      if (sql.includes("set_config('app.actor_id'")) {
+        context.actorSettings.set("app.actor_id", String(values[0] ?? ""));
+        return 1;
+      }
+
+      if (sql.includes("SELECT pg_advisory_xact_lock(hashtext(")) {
+        const key = String(values[0] ?? "");
+        await locks.acquire(key, txId);
+        context.ownedLocks.add(key);
+        return 1;
+      }
+
+      if (sql.includes('INSERT INTO "IdempotencyKey"')) {
+        prepare(
+          db,
+          `INSERT INTO "IdempotencyKey" (
+            id, key, "userId", endpoint, status, "requestHash", "createdAt", "expiresAt"
+          )
+          VALUES (?, ?, ?, ?, 'processing', ?, CURRENT_TIMESTAMP, datetime(CURRENT_TIMESTAMP, '+24 hours'))
+          ON CONFLICT ("userId", endpoint, key) DO NOTHING`
+        ).run(randomUUID(), values[0], values[1], values[2], values[3]);
+        return 1;
+      }
+
+      if (sql.includes('UPDATE "IdempotencyKey"') && sql.includes("SET status = 'completed'")) {
+        prepare(
+          db,
+          `UPDATE "IdempotencyKey"
+           SET status = 'completed',
+               "requestHash" = ?,
+               "resultData" = ?
+           WHERE id = ?`
+        ).run(values[0], values[1], values[2]);
+        return 1;
+      }
+
+      throw new Error(`Unsupported $executeRaw SQL in Phase 01 test harness: ${sql}`);
+    },
+    async $queryRaw(strings, ...values) {
+      const sql = normalizeSql(strings);
+
+      if (sql.includes('FROM "IdempotencyKey"') && sql.includes("FOR UPDATE")) {
+        return rawQuery(
+          db,
+          `SELECT id, status, "requestHash", "resultData"
+           FROM "IdempotencyKey"
+           WHERE "userId" = ?
+             AND endpoint = ?
+             AND key = ?`,
+          values
+        ) as never;
+      }
+
+      throw new Error(`Unsupported $queryRaw SQL in Phase 01 test harness: ${sql}`);
+    },
+    physicalUnit: {
+      async upsert(args) {
+        const existing = prepare(
+          db,
+          `SELECT id, unit_identity_epoch, source_version
+           FROM physical_units
+           WHERE canonical_address_hash = ?
+             AND canonical_unit = ?`
+        ).get(
+          args.where.canonicalAddressHash_canonicalUnit.canonicalAddressHash,
+          args.where.canonicalAddressHash_canonicalUnit.canonicalUnit
+        ) as Row | undefined;
+
+        if (!existing) {
+          const createdId = randomUUID();
+          prepare(
+            db,
+            `INSERT INTO physical_units (
+              id,
+              canonical_address_hash,
+              canonical_unit,
+              canonicalizer_version
+            )
+            VALUES (?, ?, ?, ?)`
+          ).run(
+            createdId,
+            args.create.canonicalAddressHash,
+            args.create.canonicalUnit,
+            args.create.canonicalizerVersion
+          );
+
+          return {
+            id: createdId,
+            unitIdentityEpoch: 1,
+            sourceVersion: BigInt(1),
+          };
+        }
+
+        prepare(
+          db,
+          `UPDATE physical_units
+           SET canonicalizer_version = ?,
+               source_version = source_version + 1,
+               row_version = row_version + 1,
+               updated_at = CURRENT_TIMESTAMP
+           WHERE id = ?`
+        ).run(args.update.canonicalizerVersion, existing.id);
+
+        const updated = prepare(
+          db,
+          `SELECT id, unit_identity_epoch, source_version
+           FROM physical_units
+           WHERE id = ?`
+        ).get(existing.id) as Row;
+
+        return {
+          id: String(updated.id),
+          unitIdentityEpoch: Number(updated.unit_identity_epoch),
+          sourceVersion: readBigInt(updated.source_version),
+        };
+      },
+      async findMany(args) {
+        const placeholders = args.where.id.in.map(() => "?").join(", ");
+        return rawQuery(
+          db,
+          `SELECT id, unit_identity_epoch, supersedes_unit_ids
+           FROM physical_units
+           WHERE id IN (${placeholders})`,
+          args.where.id.in
+        ).map((row) => ({
+          id: String(row.id),
+          unitIdentityEpoch: Number(row.unit_identity_epoch),
+          supersedesUnitIds: fromJsonArray(row.supersedes_unit_ids),
+        }));
+      },
+      async update(args) {
+        const passthrough = Object.fromEntries(
+          Object.entries(args.data).filter(
+            ([key]) =>
+              ![
+                "unitIdentityEpoch",
+                "sourceVersion",
+                "rowVersion",
+                "supersedesUnitIds",
+                "supersededByUnitId",
+              ].includes(key)
+          )
+        );
+
+        buildUpdate(db, "physical_units", args.where.id, {
+          ...passthrough,
+          ...(args.data.unitIdentityEpoch !== undefined
+            ? { unit_identity_epoch: args.data.unitIdentityEpoch }
+            : {}),
+          ...(args.data.sourceVersion !== undefined
+            ? { source_version: args.data.sourceVersion }
+            : {}),
+          ...(args.data.rowVersion !== undefined
+            ? { row_version: args.data.rowVersion }
+            : {}),
+          ...(args.data.supersedesUnitIds !== undefined
+            ? { supersedes_unit_ids: args.data.supersedesUnitIds }
+            : {}),
+          ...(args.data.supersededByUnitId !== undefined
+            ? { superseded_by_unit_id: args.data.supersededByUnitId }
+            : {}),
+        });
+      },
+    },
+    hostUnitClaim: {
+      async create(args) {
+        return buildInsert(db, "host_unit_claims", args.data);
+      },
+      async update(args) {
+        buildUpdate(db, "host_unit_claims", args.where.id, args.data);
+      },
+    },
+    listingInventory: {
+      async create(args) {
+        return buildInsert(db, "listing_inventories", args.data);
+      },
+      async update(args) {
+        buildUpdate(db, "listing_inventories", args.where.id, args.data);
+      },
+    },
+    identityMutation: {
+      async create(args) {
+        return buildInsert(db, "identity_mutations", {
+          kind: args.data.kind,
+          from_unit_ids: args.data.fromUnitIds,
+          to_unit_ids: args.data.toUnitIds,
+          reason_code: args.data.reasonCode,
+          operator_id: args.data.operatorId,
+          resulting_epoch: args.data.resultingEpoch,
+        });
+      },
+    },
+    outboxEvent: {
+      async create(args) {
+        return buildInsert(db, "outbox_events", {
+          aggregate_type: args.data.aggregateType,
+          aggregate_id: args.data.aggregateId,
+          kind: args.data.kind,
+          payload: args.data.payload,
+          source_version: args.data.sourceVersion,
+          unit_identity_epoch: args.data.unitIdentityEpoch,
+          priority: args.data.priority ?? 100,
+        });
+      },
+    },
+    auditEvent: {
+      async create(args) {
+        return buildInsert(db, "audit_events", {
+          kind: args.data.kind,
+          actor_role: args.data.actorRole,
+          actor_id: args.data.actorId,
+          aggregate_type: args.data.aggregateType,
+          aggregate_id: args.data.aggregateId,
+          details: args.data.details ?? {},
+          request_id: args.data.requestId ?? null,
+          unit_identity_epoch: args.data.unitIdentityEpoch ?? null,
+        });
+      },
+    },
+  };
+
+  return tx;
+}
+
+function createSchema(db: SQLiteDatabase): void {
+  db.exec(`
+    PRAGMA foreign_keys = ON;
+    PRAGMA journal_mode = WAL;
+
+    CREATE TABLE "User" (
+      id TEXT PRIMARY KEY
+    );
+
