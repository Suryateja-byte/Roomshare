diff --git a/src/__tests__/db/phase01-moderation-precedence.test.ts b/src/__tests__/db/phase01-moderation-precedence.test.ts
new file mode 100644
index 00000000..e989c472
--- /dev/null
+++ b/src/__tests__/db/phase01-moderation-precedence.test.ts
@@ -0,0 +1,198 @@
+import { withActor } from "@/lib/db/with-actor";
+import { ModerationLockedError } from "@/lib/identity/errors";
+import {
+  Phase01TestDb,
+  hostActor,
+  moderatorActor,
+} from "@/__tests__/utils/phase01-test-db";
+
+describe("Phase 01 moderation-precedence and append-only triggers", () => {
+  let db: Phase01TestDb;
+  let physicalUnitId: string;
+  let claimId: string;
+  let inventoryId: string;
+
+  beforeEach(() => {
+    db = new Phase01TestDb();
+    db.insertUser("host-1");
+    db.insertUser("moderator-1");
+
+    physicalUnitId = db.insertPhysicalUnit({
+      id: "unit-mod",
+      canonical_address_hash: "hash-mod",
+    });
+    claimId = db.insertHostUnitClaim({
+      id: "claim-mod",
+      unit_id: physicalUnitId,
+      host_user_id: "host-1",
+      canonical_address_hash: "hash-mod",
+    });
+    inventoryId = db.insertListingInventory({
+      id: "inventory-mod",
+      unit_id: physicalUnitId,
+      canonical_address_hash: "hash-mod",
+      room_category: "PRIVATE_ROOM",
+      capacity_guests: 1,
+    });
+  });
+
+  afterEach(() => {
+    db.dispose();
+  });
+
+  it.each([
+    ["publish_status", "PUBLISHED"],
+    ["lifecycle_status", "PAUSED"],
+    ["privacy_version", 2],
+  ])("host role cannot update %s on physical_units", async (column, value) => {
+    await expect(
+      withActor(
+        hostActor(),
+        async (tx) => {
+          await (tx as any).physicalUnit.update({
+            where: { id: physicalUnitId },
+            data: { [column]: value },
+          });
+        },
+        { client: db.client as never }
+      )
+    ).rejects.toBeInstanceOf(ModerationLockedError);
+
+    const row = db.get<{ publish_status: string; lifecycle_status: string; privacy_version: number }>(
+      `SELECT publish_status, lifecycle_status, privacy_version
+       FROM physical_units
+       WHERE id = ?`,
+      [physicalUnitId]
+    );
+
+    expect(row).toEqual({
+      publish_status: "DRAFT",
+      lifecycle_status: "ACTIVE",
+      privacy_version: 1,
+    });
+  });
+
+  it("moderator role can update publish_status on all three canonical tables", async () => {
+    await withActor(
+      moderatorActor(),
+      async (tx) => {
+        await (tx as any).physicalUnit.update({
+          where: { id: physicalUnitId },
+          data: { publish_status: "PUBLISHED" },
+        });
+        await (tx as any).hostUnitClaim.update({
+          where: { id: claimId },
+          data: { publish_status: "PUBLISHED" },
+        });
+        await (tx as any).listingInventory.update({
+          where: { id: inventoryId },
+          data: { publish_status: "PUBLISHED" },
+        });
+      },
+      { client: db.client as never }
+    );
+
+    expect(
+      db.get<{ publish_status: string }>(
+        `SELECT publish_status FROM physical_units WHERE id = ?`,
+        [physicalUnitId]
+      ).publish_status
+    ).toBe("PUBLISHED");
+    expect(
+      db.get<{ publish_status: string }>(
+        `SELECT publish_status FROM host_unit_claims WHERE id = ?`,
+        [claimId]
+      ).publish_status
+    ).toBe("PUBLISHED");
+    expect(
+      db.get<{ publish_status: string }>(
+        `SELECT publish_status FROM listing_inventories WHERE id = ?`,
+        [inventoryId]
+      ).publish_status
+    ).toBe("PUBLISHED");
+  });
+
+  it("missing actor_role defaults to system and passes", async () => {
+    await db.client.$transaction(async (tx) => {
+      await (tx as any).physicalUnit.update({
+        where: { id: physicalUnitId },
+        data: { publish_status: "PUBLISHED" },
+      });
+    });
+
+    expect(
+      db.get<{ publish_status: string }>(
+        `SELECT publish_status FROM physical_units WHERE id = ?`,
+        [physicalUnitId]
+      ).publish_status
+    ).toBe("PUBLISHED");
+  });
+
+  it("trigger applies to all three canonical tables for host-role updates", async () => {
+    await expect(
+      withActor(
+        hostActor(),
+        async (tx) => {
+          await (tx as any).hostUnitClaim.update({
+            where: { id: claimId },
+            data: { publish_status: "PUBLISHED" },
+          });
+        },
+        { client: db.client as never }
+      )
+    ).rejects.toBeInstanceOf(ModerationLockedError);
+
+    await expect(
+      withActor(
+        hostActor(),
+        async (tx) => {
+          await (tx as any).listingInventory.update({
+            where: { id: inventoryId },
+            data: { publish_status: "PUBLISHED" },
+          });
+        },
+        { client: db.client as never }
+      )
+    ).rejects.toBeInstanceOf(ModerationLockedError);
+  });
+
+  it("identity_mutations rejects UPDATE and DELETE", () => {
+    const mutationId = db.insertIdentityMutation({
+      id: "mutation-mod",
+      from_unit_ids: [physicalUnitId],
+      to_unit_ids: [physicalUnitId],
+    });
+
+    expect(() =>
+      db.run(
+        `UPDATE identity_mutations
+         SET reason_code = 'manual_moderation'
+         WHERE id = ?`,
+        [mutationId]
+      )
+    ).toThrow(/append-only/i);
+
+    expect(() =>
+      db.run(`DELETE FROM identity_mutations WHERE id = ?`, [mutationId])
+    ).toThrow(/append-only/i);
+  });
+
+  it("audit_events rejects UPDATE and DELETE", () => {
+    const auditId = db.insertAuditEvent({
+      id: "audit-mod",
+    });
+
+    expect(() =>
+      db.run(
+        `UPDATE audit_events
+         SET kind = 'CANONICAL_UNIT_CREATED'
+         WHERE id = ?`,
+        [auditId]
+      )
+    ).toThrow(/append-only/i);
+
+    expect(() => db.run(`DELETE FROM audit_events WHERE id = ?`, [auditId])).toThrow(
+      /append-only/i
+    );
+  });
+});
