+import { Phase01TestDb, hostActor } from "@/__tests__/utils/phase01-test-db";
+import { ModerationLockedError } from "@/lib/identity/errors";
+import { withActor } from "@/lib/db/with-actor";
+
+describe("withActor", () => {
+  let db: Phase01TestDb;
+
+  beforeEach(() => {
+    db = new Phase01TestDb();
+  });
+
+  afterEach(() => {
+    db.dispose();
+  });
+
+  it("makes actor_role visible inside the transaction via current_setting", async () => {
+    const result = await withActor(
+      hostActor("user-1"),
+      async (tx) => db.currentSettingInTx(tx as never, "app.actor_role"),
+      { client: db.client as never }
+    );
+
+    expect(result).toBe("host");
+  });
+
+  it("auto-resets actor GUCs outside the transaction", async () => {
+    await withActor(hostActor("user-1"), async () => "ok", {
+      client: db.client as never,
+    });
+
+    expect(db.currentSettingOutsideTx("app.actor_role")).toBeNull();
+  });
+
+  it("leaves no actor GUC residue after a rolled-back transaction", async () => {
+    await expect(
+      withActor(
+        hostActor("user-1"),
+        async (tx) => {
+          expect(db.currentSettingInTx(tx as never, "app.actor_role")).toBe("host");
+          throw new Error("rollback me");
+        },
+        { client: db.client as never }
+      )
+    ).rejects.toThrow("rollback me");
+
+    expect(db.currentSettingOutsideTx("app.actor_role")).toBeNull();
+  });
+
+  it("translates moderation trigger failures", async () => {
+    const unitId = db.insertPhysicalUnit({
+      id: "unit-locked",
+      canonical_address_hash: "hash-locked",
+    });
+
+    await expect(
+      withActor(
+        hostActor("user-1"),
+        async (tx) => {
+          await (tx as any).physicalUnit.update({
+            where: { id: unitId },
+            data: { publish_status: "PUBLISHED" },
+          });
+        },
+        { client: db.client as never }
+      )
+    ).rejects.toBeInstanceOf(ModerationLockedError);
+  });
+});
