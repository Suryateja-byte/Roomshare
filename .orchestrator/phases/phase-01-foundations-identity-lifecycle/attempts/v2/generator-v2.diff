+import { withActor } from "@/lib/db/with-actor";
+import { resolveOrCreateUnit } from "@/lib/identity/resolve-or-create-unit";
+import { validateInventoryInput } from "@/lib/validation/category";
+import {
+  Phase01TestDb,
+  hostActor,
+} from "@/__tests__/utils/phase01-test-db";
+
+describe("Phase 01 schema and DB contracts", () => {
+  let db: Phase01TestDb;
+
+  beforeEach(() => {
+    db = new Phase01TestDb();
+    db.insertUser("host-1");
+    db.insertUser("moderator-1");
+  });
+
+  afterEach(() => {
+    db.dispose();
+  });
+
+  it("creates the seven canonical tables, required indexes, and Listing.physical_unit_id", () => {
+    expect(db.listTables()).toEqual(
+      expect.arrayContaining([
+        "physical_units",
+        "host_unit_claims",
+        "listing_inventories",
+        "identity_mutations",
+        "outbox_events",
+        "cache_invalidations",
+        "audit_events",
+      ])
+    );
+
+    expect(db.listIndexes()).toEqual(
+      expect.arrayContaining([
+        "physical_units_canonical_unique_idx",
+        "outbox_events_pending_idx",
+        "outbox_events_aggregate_idx",
+        "outbox_events_dlq_idx",
+        "cache_invalidations_pending_idx",
+        "cache_invalidations_unit_enqueued_idx",
+        "audit_events_aggregate_idx",
+        "audit_events_kind_idx",
+        "audit_events_actor_idx",
+      ])
+    );
+
+    const columns = db
+      .all<{ name: string }>(`PRAGMA table_info("Listing")`)
+      .map((column) => column.name);
+
+    expect(columns).toContain("physical_unit_id");
+  });
+
+  it.each([
+    [
+      "ENTIRE_PLACE rejects non-null total_beds",
+      {
+        room_category: "ENTIRE_PLACE",
+        total_beds: 2,
+      },
+    ],
+    [
+      "SHARED_ROOM rejects null open_beds",
+      {
+        room_category: "SHARED_ROOM",
+        capacity_guests: null,
+        total_beds: 2,
+        open_beds: null,
+      },
+    ],
+    [
+      "PRIVATE_ROOM rejects non-null total_beds",
+      {
+        room_category: "PRIVATE_ROOM",
+        total_beds: 1,
+      },
+    ],
+    [
+      "SHARED_ROOM rejects open_beds > total_beds",
+      {
+        room_category: "SHARED_ROOM",
+        capacity_guests: null,
+        total_beds: 2,
+        open_beds: 3,
+      },
+    ],
+    [
+      "ENTIRE_PLACE rejects non-null gender_preference",
+      {
+        room_category: "ENTIRE_PLACE",
+        gender_preference: "women",
+      },
+    ],
+  ])("%s", (_label, overrides) => {
+    const unitId = db.insertPhysicalUnit({
+      id: "unit-schema",
+      canonical_address_hash: "hash-schema",
+    });
+
+    expect(() =>
+      db.insertListingInventory({
+        id: `${String(overrides.room_category ?? "inv")}-row`,
+        unit_id: unitId,
+        canonical_address_hash: "hash-schema",
+        ...overrides,
+      })
+    ).toThrow(/constraint|check/i);
+  });
+
+  it("accepts a valid ENTIRE_PLACE row at the DB boundary", () => {
+    const unitId = db.insertPhysicalUnit({
+      id: "unit-valid",
+      canonical_address_hash: "hash-valid",
+    });
+
+    expect(() =>
+      db.insertListingInventory({
+        id: "inventory-valid",
+        unit_id: unitId,
+        canonical_address_hash: "hash-valid",
+        room_category: "ENTIRE_PLACE",
+        capacity_guests: 3,
+        total_beds: null,
+        open_beds: null,
+        gender_preference: null,
+        household_gender: null,
+      })
+    ).not.toThrow();
+  });
+
+  it("keeps availability_range present and constrained to a valid tstzrange literal", () => {
+    const unitId = db.insertPhysicalUnit({
+      id: "unit-range",
+      canonical_address_hash: "hash-range",
+    });
+
+    db.insertListingInventory({
+      id: "inventory-range-valid",
+      unit_id: unitId,
+      canonical_address_hash: "hash-range",
+      room_category: "PRIVATE_ROOM",
+      capacity_guests: 1,
+      availability_range: "[2026-05-01T00:00:00Z,2026-06-01T00:00:00Z)",
+    });
+
+    expect(() =>
+      db.insertListingInventory({
+        id: "inventory-range-invalid",
+        unit_id: unitId,
+        canonical_address_hash: "hash-range",
+        room_category: "PRIVATE_ROOM",
+        capacity_guests: 1,
+        availability_range: "not-a-range",
+      })
+    ).toThrow(/constraint|check/i);
+  });
+
+  it("rejects an UPDATE that would violate the category matrix", () => {
+    const unitId = db.insertPhysicalUnit({
+      id: "unit-update-check",
+      canonical_address_hash: "hash-update-check",
+    });
+    const inventoryId = db.insertListingInventory({
+      id: "inventory-update-check",
+      unit_id: unitId,
+      canonical_address_hash: "hash-update-check",
+      room_category: "PRIVATE_ROOM",
+      capacity_guests: 1,
+    });
+
+    expect(() =>
+      db.run(
+        `UPDATE "listing_inventories"
+         SET room_category = 'SHARED_ROOM'
+         WHERE id = ?`,
+        [inventoryId]
+      )
+    ).toThrow(/constraint|check/i);
+  });
+
+  it("resolveOrCreateUnit collapses the five canonical address variants into one row", async () => {
+    const actor = hostActor();
+    const variants = [
+      "123 Main St Apt 4B",
+      "  123  main  st  apt 4B ",
+      "123 MAIN ST APT 4B",
+      "123 Main St. Apt 4B",
+      "123 Main Street Apt 4B",
+    ];
+
+    const results: Array<{ created: boolean }> = [];
+    for (const address of variants) {
+      results.push(
+        await withActor(
+          actor,
+          async (tx) =>
+            resolveOrCreateUnit(tx as never, {
+              actor,
+              address: {
+                address,
+                city: "San Francisco",
+                state: "ca",
+                zip: "94107-1234",
+              },
+            }),
+          { client: db.client as never }
+        )
+      );
+    }
+
+    expect(db.getPhysicalUnits()).toHaveLength(1);
+    expect(results.filter((result) => result.created)).toHaveLength(1);
+  });
+
+  it("increments source_version and row_version on repeated upserts", async () => {
+    const actor = hostActor();
+    const address = {
+      address: "500 Market Street",
+      city: "San Francisco",
+      state: "CA",
+      zip: "94105",
+    };
+
+    await withActor(
+      actor,
+      async (tx) =>
+        resolveOrCreateUnit(tx as never, {
+          actor,
+          address,
+        }),
+      { client: db.client as never }
+    );
+
+    expect(db.getPhysicalUnits()[0]).toEqual(
+      expect.objectContaining({
+        sourceVersion: BigInt(1),
+        rowVersion: BigInt(1),
+      })
+    );
+
+    await withActor(
+      actor,
+      async (tx) =>
+        resolveOrCreateUnit(tx as never, {
+          actor,
+          address,
+        }),
+      { client: db.client as never }
+    );
+
+    expect(db.getPhysicalUnits()[0]).toEqual(
+      expect.objectContaining({
+        sourceVersion: BigInt(2),
+        rowVersion: BigInt(2),
+      })
+    );
+  });
+
+  it("rejects invalid SHARED_ROOM shapes at the zod layer before the DB write", () => {
+    const result = validateInventoryInput({
+      roomCategory: "SHARED_ROOM",
+      inventoryKey: "shared-1",
+      availableFrom: "2026-05-01",
+      availabilityRange: "[2026-05-01T00:00:00Z,2026-06-01T00:00:00Z)",
+      price: 900,
+      totalBeds: 2,
+      openBeds: 3,
+    });
+
+    expect(result.ok).toBe(false);
+  });
+});
diff --git a/src/__tests__/integration/phase01-read-path-isolation.test.ts b/src/__tests__/integration/phase01-read-path-isolation.test.ts
new file mode 100644
index 00000000..100c9cc0
--- /dev/null
+++ b/src/__tests__/integration/phase01-read-path-isolation.test.ts
@@ -0,0 +1,110 @@
+import fs from "fs";
+import path from "path";
+
+const TEXT_EXTENSIONS = new Set([
+  ".ts",
+  ".tsx",
+  ".js",
+  ".jsx",
+  ".json",
+  ".md",
+  ".sql",
+  ".prisma",
+]);
+
+function walkFiles(root: string): string[] {
+  const entries = fs.readdirSync(root, { withFileTypes: true });
+  const files: string[] = [];
+
+  for (const entry of entries) {
+    if (
+      [".next", ".worktrees", "coverage", "node_modules", "test-output"].includes(
+        entry.name
+      )
+    ) {
+      continue;
+    }
+
+    const fullPath = path.join(root, entry.name);
+    if (entry.isDirectory()) {
+      files.push(...walkFiles(fullPath));
+      continue;
+    }
+
+    if (!TEXT_EXTENSIONS.has(path.extname(entry.name))) {
+      continue;
+    }
+
+    files.push(fullPath);
+  }
+
+  return files;
+}
+
+function findMatches(term: string): string[] {
+  const repoRoot = process.cwd();
+  const searchRoots = ["src", "prisma", ".orchestrator"].map((dir) =>
+    path.join(repoRoot, dir)
+  );
+  const matches: string[] = [];
+
+  for (const root of searchRoots) {
+    for (const file of walkFiles(root)) {
+      const relative = path.relative(repoRoot, file);
+      const content = fs.readFileSync(file, "utf8");
+      if (content.includes(term)) {
+        matches.push(relative);
+      }
+    }
+  }
+
+  return matches;
+}
+
+describe("Phase 01 read-path isolation", () => {
+  const terms = [
+    "listing_inventories",
+    "ListingInventory",
+    "physical_units",
+    "host_unit_claims",
+    "identity_mutations",
+    "outbox_events",
+    "cache_invalidations",
+    "audit_events",
+  ];
+
+  it("keeps new table references out of app and component read paths", () => {
+    for (const term of terms) {
+      const hits = findMatches(term);
+      const offending = hits.filter(
+        (file) => file.startsWith("src/app/") || file.startsWith("src/components/")
+      );
+      expect(offending).toEqual([]);
+    }
+  });
+
+  it("keeps Listing.physical_unit_id unread by app and component code", () => {
+    const hits = findMatches("physical_unit_id");
+    const offending = hits.filter(
+      (file) =>
+        (file.startsWith("src/app/") || file.startsWith("src/components/")) &&
+        file !== "src/__tests__/integration/phase01-read-path-isolation.test.ts"
+    );
+    expect(offending).toEqual([]);
+  });
+
+  it("keeps isPhase01CanonicalWritesEnabled uncoupled from production callers", () => {
+    const hits = findMatches("isPhase01CanonicalWritesEnabled");
+    const allowed = new Set([
+      "src/lib/flags/phase01.ts",
+      "src/__tests__/integration/phase01-read-path-isolation.test.ts",
+      "src/__tests__/lib/flags/phase01.test.ts",
+    ]);
+
+    const offending = hits.filter(
+      (file) => file.startsWith("src/") && !allowed.has(file)
+    );
+
+    expect(offending).toEqual([]);
+  });
+});
