+import {
+  IDEMPOTENCY_ENDPOINT_RESOLVE_UNIT,
+  type IdempotencySuccess,
+  withIdempotency,
+} from "@/lib/idempotency";
+import { resolveOrCreateUnit } from "@/lib/identity/resolve-or-create-unit";
+import {
+  Phase01TestDb,
+  hostActor,
+} from "@/__tests__/utils/phase01-test-db";
+
+describe("Phase 01 advisory-lock contention", () => {
+  let db: Phase01TestDb;
+
+  beforeEach(() => {
+    db = new Phase01TestDb();
+  });
+
+  afterEach(() => {
+    db.dispose();
+  });
+
+  it("10 parallel callers converge on one physical_units row and 9 resolve existing", async () => {
+    const actor = hostActor();
+    const address = {
+      address: "123 Main St Apt 4B",
+      city: "San Francisco",
+      state: "CA",
+      zip: "94107",
+    };
+
+    const results = await Promise.all(
+      Array.from({ length: 10 }, (_, index) =>
+        withIdempotency<{ created: boolean }>(
+          `phase01-lock-${index}`,
+          "host-1",
+          IDEMPOTENCY_ENDPOINT_RESOLVE_UNIT,
+          address,
+          (tx) =>
+            resolveOrCreateUnit(tx as never, {
+              actor,
+              address,
+              requestId: `req-${index}`,
+            }),
+          { client: db.client as never }
+        )
+      )
+    );
+
+    expect(results.every((result) => result.success)).toBe(true);
+    const successes = results.filter(
+      (result): result is IdempotencySuccess<{ created: boolean }> => result.success
+    );
+
+    expect(successes).toHaveLength(10);
+    expect(successes.filter((result) => result.result.created)).toHaveLength(1);
+    expect(successes.filter((result) => !result.result.created)).toHaveLength(9);
+    expect(db.getPhysicalUnits()).toHaveLength(1);
+  });
+});
diff --git a/src/__tests__/integration/phase01-identity-mutation.test.ts b/src/__tests__/integration/phase01-identity-mutation.test.ts
