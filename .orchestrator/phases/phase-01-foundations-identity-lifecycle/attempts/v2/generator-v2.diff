+  constructor() {
+    this.baseDb = new DatabaseSync(this.dbPath);
+    registerFunctions(this.baseDb, null);
+    createSchema(this.baseDb);
+    this.client = {
+      $transaction: async (fnOrArray) => {
+        if (Array.isArray(fnOrArray)) {
+          return Promise.all(fnOrArray) as never;
+        }
+
+        return this.queue.run(async () => {
+          const context = createContext();
+          const txDb = new DatabaseSync(this.dbPath);
+          registerFunctions(txDb, context);
+          txDb.exec("BEGIN");
+          const txId = randomUUID();
+          const tx = createTransactionClient(txDb, context, txId, this.locks);
+
+          try {
+            const result = await fnOrArray(tx);
+            txDb.exec("COMMIT");
+            return result;
+          } catch (error) {
+            txDb.exec("ROLLBACK");
+            throw error;
+          } finally {
+            this.locks.releaseAll(txId);
+            txDb.close();
+          }
+        });
+      },
+    };
+  }
