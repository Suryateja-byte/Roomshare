# ============================================================================
# Roomshare Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in the values.
# Required vars are marked [REQUIRED], optional ones [OPTIONAL].
#
# Environment contexts:
#   DEV  = local development
#   PROD = production deployment
#   CI   = continuous integration / E2E tests
# ============================================================================

# ============================================================================
# DATABASE
# ============================================================================
# [REQUIRED] PostgreSQL connection string (PostGIS-enabled)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
# Local dev uses docker-compose on port 5433
DATABASE_URL=postgresql://postgres:password@localhost:5433/roomshare?schema=public

# --- Docker Compose Postgres (used by docker-compose.yml) ---
# [OPTIONAL] Override defaults for the local Postgres container
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=password
# POSTGRES_DB=roomshare

# [OPTIONAL] Run Prisma DB assertions on startup (DEV only)
# RUN_DB_ASSERTIONS=true

# ============================================================================
# AUTHENTICATION (NextAuth v5 / Auth.js)
# ============================================================================
# [REQUIRED] Session encryption secret — generate with: openssl rand -base64 32
# Must be at least 32 characters. AUTH_SECRET is the v5 name; NEXTAUTH_SECRET
# is the legacy name — the app checks both.
NEXTAUTH_SECRET=your-nextauth-secret-at-least-32-characters-long
# AUTH_SECRET=                  # [OPTIONAL] v5 alias — falls back to NEXTAUTH_SECRET

# [REQUIRED] Canonical URL of the app (used for callback URLs)
NEXTAUTH_URL=http://localhost:3000
# AUTH_URL=                     # [OPTIONAL] v5 alias — falls back to NEXTAUTH_URL

# [OPTIONAL] Trust the Host header (set to "true" behind a reverse proxy / Vercel)
AUTH_TRUST_HOST=true

# --- Google OAuth ---
# [REQUIRED] Google OAuth credentials (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================================================
# SECURITY SECRETS
# ============================================================================
# [REQUIRED in PROD] Cron job authentication
# Generate with: openssl rand -base64 32 (at least 32 characters)
CRON_SECRET=generate-secure-secret-at-least-32-chars

# [REQUIRED in PROD] HMAC secret for privacy-safe metrics logging
# Generate with: openssl rand -hex 32
LOG_HMAC_SECRET=generate-with-openssl-rand-hex-32-chars

# [REQUIRED in PROD] Cursor signing secret (prevents cursor tampering in pagination)
# Generate with: openssl rand -hex 32
CURSOR_SECRET=

# [REQUIRED in PROD] Metrics ops endpoint authentication
# Generate with: openssl rand -base64 32 (at least 32 characters)
METRICS_SECRET=generate-secure-secret-at-least-32-chars

# ============================================================================
# ORIGIN / HOST SECURITY (Production)
# ============================================================================
# [REQUIRED in PROD] Comma-separated, no trailing slashes
# Used by /api/agent, /api/chat, and /api/metrics for request validation
ALLOWED_ORIGINS=https://roomshare.com,https://www.roomshare.com
ALLOWED_HOSTS=roomshare.com,www.roomshare.com

# [OPTIONAL] Trust CDN headers (e.g., cf-connecting-ip) for rate limiting
# Set to "true" only if behind Cloudflare or similar CDN
# TRUST_CDN_HEADERS=true

# [OPTIONAL] Trust proxy headers (x-forwarded-for) for rate limiting
# Set to "true" behind a reverse proxy in production
# TRUST_PROXY=true

# ============================================================================
# ERROR TRACKING (Sentry)
# ============================================================================
# [OPTIONAL] Sentry DSN for error tracking
SENTRY_DSN=https://your-sentry-dsn
# IMPORTANT: NEXT_PUBLIC_SENTRY_DSN must be set separately for client-side error tracking
# It is NOT auto-mapped from SENTRY_DSN
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn

# [OPTIONAL] Sentry auth token for source map uploads during build
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# [OPTIONAL] Sentry org and project slugs (required for source map uploads)
# SENTRY_ORG=your-sentry-org
# SENTRY_PROJECT=your-sentry-project

# [OPTIONAL] Enable Sentry in development (default: off, production always on)
# SENTRY_ENABLE_IN_DEV=1
# NEXT_PUBLIC_SENTRY_ENABLE_IN_DEV=1

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================

# --- Geocoding ---
# Geocoding uses Photon + Nominatim (free, no API key needed)
# Map rendering uses OpenFreeMap (free, no API key needed)

# [OPTIONAL] HERE Maps — for geocoding accuracy comparison scripts
# Get a free API key from: https://developer.here.com/
# HERE_API_KEY=your-here-api-key

# --- Supabase (Storage & Realtime) ---
# [REQUIRED] Supabase project URL and anon key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# [REQUIRED in PROD] Service role key for server-side operations
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- Email (Resend) ---
# [OPTIONAL] Resend API key for transactional emails
RESEND_API_KEY=your-resend-api-key
FROM_EMAIL=RoomShare <onboarding@resend.dev>

# --- AI Chat (Groq) ---
# [OPTIONAL] Groq API key for AI chat features
# GROQ_API_KEY=your-groq-api-key

# --- N8N Webhook (Agent API) ---
# [OPTIONAL] N8N webhook URL for the /api/agent endpoint
# N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/your-webhook-id

# ============================================================================
# RATE LIMITING (Upstash Redis)
# ============================================================================
# [OPTIONAL] Falls back to database rate limiting if not configured
# Get from https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# [OPTIONAL] Disable the 10x dev multiplier for rate limits (DEV only)
# DISABLE_RATE_LIMIT_DEV_MULTIPLIER=true

# ============================================================================
# GOOGLE MAPS / PLACES
# ============================================================================
# [OPTIONAL] Browser key for Maps JavaScript API (HTTP referrer restricted)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-browser-key

# [OPTIONAL] Browser key for Places UI Kit (HTTP referrer restricted)
NEXT_PUBLIC_GOOGLE_MAPS_UIKIT_KEY=your-google-maps-uikit-browser-key

# [OPTIONAL] Server key for backend geocoding (IP restricted)
# GOOGLE_PLACES_API_KEY=your-google-places-server-key

# ============================================================================
# RADAR (Nearby Places Search)
# ============================================================================
# Get API keys from https://radar.com/dashboard

# [OPTIONAL] Secret key (server-side only, IP restricted) — NEVER expose to client
RADAR_SECRET_KEY=prj_live_sk_...

# [OPTIONAL] Publishable key (for map style URL, browser-safe)
NEXT_PUBLIC_RADAR_PUBLISHABLE_KEY=prj_live_pk_...

# [OPTIONAL] Feature flag to enable/disable Nearby Places section
NEXT_PUBLIC_NEARBY_ENABLED=true

# ============================================================================
# STADIA MAPS (Basemap Tiles)
# ============================================================================
# Get API key from https://client.stadiamaps.com/
# Uses Alidade Smooth style with dark mode support.
#
# AUTHENTICATION OPTIONS:
# 1. Domain auth (RECOMMENDED for production):
#    - Add your domain at client.stadiamaps.com
#    - No API key needed in code
# 2. API key (fallback):
#    - Use query string ?api_key=YOUR_KEY
#    - Set the variable below
#
# DEVELOPMENT: localhost/127.0.0.1 works without API key
# COMMERCIAL USE: Free tier 200,000 credits/month (non-commercial only)
#
NEXT_PUBLIC_STADIA_API_KEY=your-stadia-api-key
# STADIA_API_KEY=                # [OPTIONAL] Server-side alias (rarely needed)

# ============================================================================
# MAPBOX (Scripts Only)
# ============================================================================
# [OPTIONAL] Used by geocoding accuracy check scripts, NOT by the main app
# NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-token
# MAPBOX_ACCESS_TOKEN=your-mapbox-token

# ============================================================================
# CLOUDFLARE TURNSTILE (Bot Protection)
# ============================================================================
# Free bot protection for auth forms. Get keys from https://dash.cloudflare.com/turnstile
# Set TURNSTILE_ENABLED=true + provide both keys to activate.
# Test keys below auto-pass without user interaction (for dev/E2E).
TURNSTILE_ENABLED=true
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# --- Multi-Slot Booking (Phase 0+) ---
# Omit or leave commented to disable — all default OFF when absent
# ENABLE_MULTI_SLOT_BOOKING=true
# ENABLE_WHOLE_UNIT_MODE=true        # requires MULTI_SLOT
# ENABLE_SOFT_HOLDS=on               # requires MULTI_SLOT; values: on|drain|off
# ENABLE_BOOKING_AUDIT=true          # requires SOFT_HOLDS=on
# ENABLE_CONTACT_FIRST_LISTINGS=true # listing detail becomes contact-first; new bookings/holds blocked

# --- AI / Embeddings ---
# GEMINI_API_KEY=your-gemini-api-key
# ENABLE_SEMANTIC_SEARCH=false
# NEXT_PUBLIC_ENABLE_SEMANTIC_SEARCH=false  # Show "What are you looking for?" field in search UI
# ENABLE_IMAGE_EMBEDDINGS=false             # Include listing photos in embeddings (requires SEMANTIC_SEARCH)
# ENABLE_SEARCH_TEST_SCENARIOS=false        # Test-only deterministic search seam for Playwright release-gate runs
# SEMANTIC_WEIGHT=0.6                       # Weight for semantic vs keyword search (0.0-1.0)

# --- Search Tuning ---
# ENABLE_SEARCH_DOC=true             # Enable denormalized search docs table (faster text search)
# SEARCH_DOC_BATCH_SIZE=100          # Batch size for search doc generation
# SEARCH_DEBUG_RANKING=true          # Log search ranking debug info (DEV only)

# --- UI Feature Flags ---
# NEXT_PUBLIC_FORCE_PRO_MODE=true    # Force pro subscription mode in DEV (bypasses subscription check)
# NEXT_PUBLIC_PRIMARY_PINS=true      # Enable primary pin markers on map
# NEXT_PUBLIC_E2E=true               # Signal to client that E2E test mode is active

# ============================================================================
# APPLICATION
# ============================================================================
# [REQUIRED] Base URL for the application (used in emails, sitemap, SEO)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# [OPTIONAL] Server port (default: 3000)
# PORT=3000

# [OPTIONAL] Disable dev warmup script on WSL (DEV only)
# ROOMSHARE_DISABLE_DEV_WARMUP=1

# ============================================================================
# NODE ENVIRONMENT
# ============================================================================
NODE_ENV=development

# ============================================================================
# VERCEL / NEXT.JS (Auto-injected — do NOT set locally)
# ============================================================================
# These are automatically set by Vercel/Next.js during deployment and builds:
# VERCEL_ENV=production|preview|development
# VERCEL_GIT_COMMIT_SHA=abc123...
# NEXT_PUBLIC_VERCEL_ENV=production|preview|development
# NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA=abc123...
# NEXT_PHASE=phase-production-build      (set by Next.js during build)

# ============================================================================
# E2E TESTING (Playwright)
# ============================================================================
# Base URL for E2E tests (defaults to http://localhost:3000)
E2E_BASE_URL=http://localhost:3000

# Test user credentials (create a dedicated test user)
E2E_TEST_EMAIL=test@example.com
E2E_TEST_PASSWORD=TestPassword123!

# Admin test user credentials (for admin flow tests)
E2E_ADMIN_EMAIL=admin@example.com
E2E_ADMIN_PASSWORD=AdminPassword123!

# [OPTIONAL] Additional E2E test passwords (used in specific test scenarios)
# E2E_TEST_NEW_PASSWORD=NewTestPassword123!
# E2E_TEST_WRONG_PASSWORD=WrongPassword123!

# [OPTIONAL] Disable rate limiting during E2E tests
# E2E_DISABLE_RATE_LIMIT=true

# [OPTIONAL] Enable E2E test helper endpoints (/__e2e/seed, etc.)
# E2E_TEST_HELPERS=true

# Secret for E2E test helpers API auth (min 16 chars, required when E2E_TEST_HELPERS=true)
# E2E_TEST_SECRET=your-e2e-test-secret-here
